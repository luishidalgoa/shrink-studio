<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                    xmlns:local="clr-namespace:ShrinkVideo">

  <!-- ══ Nocturne — tokens (de Claude Design) ══ -->
  <Color x:Key="c.bg">#161826</Color>
  <Color x:Key="c.surface">#232532</Color>
  <Color x:Key="c.field">#292B31</Color>
  <Color x:Key="c.text">#E9E9ED</Color>
  <Color x:Key="c.accent">#968AE0</Color>

  <SolidColorBrush x:Key="Bg" Color="#161826"/>
  <SolidColorBrush x:Key="Surface" Color="#232532"/>
  <SolidColorBrush x:Key="Field" Color="#292B31"/>
  <SolidColorBrush x:Key="Text" Color="#E9E9ED"/>
  <SolidColorBrush x:Key="Neutral300" Color="#CFD3E5"/>
  <SolidColorBrush x:Key="Neutral400" Color="#B2B6CA"/>
  <SolidColorBrush x:Key="Neutral500" Color="#9397AB"/>
  <SolidColorBrush x:Key="Neutral600" Color="#75798C"/>
  <SolidColorBrush x:Key="Neutral700" Color="#595D6C"/>
  <SolidColorBrush x:Key="Neutral800" Color="#3F424D"/>
  <SolidColorBrush x:Key="Divider" Color="#29E9E9ED"/>
  <SolidColorBrush x:Key="Accent" Color="#968AE0"/>
  <SolidColorBrush x:Key="Accent200" Color="#E7E5FE"/>
  <SolidColorBrush x:Key="Accent300" Color="#D2CEFD"/>
  <SolidColorBrush x:Key="Accent400" Color="#B5ABFC"/>
  <SolidColorBrush x:Key="Accent600" Color="#796CBF"/>
  <SolidColorBrush x:Key="Accent700" Color="#5D5294"/>
  <SolidColorBrush x:Key="Accent800" Color="#423A6A"/>
  <SolidColorBrush x:Key="Accent900" Color="#2B2741"/>
  <SolidColorBrush x:Key="HoverPrimary" Color="#25263C"/>
  <SolidColorBrush x:Key="PressedPrimary" Color="#333250"/>
  <SolidColorBrush x:Key="RowSelected" Color="#232338"/>
  <SolidColorBrush x:Key="RowHover" Color="#1F2130"/>

  <!-- Menús: contrastes comprobados sobre Surface (#232532).
       MenuHighlight 2,2:1 frente al panel (el resalte antiguo, Accent900, daba 1,06:1
       y era casi invisible) y 5,6:1 con el texto → AA. MenuGesture 5,3:1 (antes 3,5:1,
       fallaba AA). MenuDisabled 3,5:1: legible pero claramente apagado. -->
  <SolidColorBrush x:Key="MenuHighlight" Color="#5D5294"/>
  <SolidColorBrush x:Key="MenuGesture" Color="#9397AB"/>
  <SolidColorBrush x:Key="MenuDisabled" Color="#75798C"/>
  <SolidColorBrush x:Key="MenuSeparator" Color="#3A3E4E"/>

  <!-- Estados de la tabla. Contraste medido sobre Surface (#232532):
       EstadoOk 8,4:1 · EstadoErr 5,3:1 — ambos por encima del 4,5:1 que pide AA. -->
  <SolidColorBrush x:Key="EstadoOk" Color="#7BD88F"/>
  <SolidColorBrush x:Key="EstadoErr" Color="#F2777A"/>

  <FontFamily x:Key="FontUI">Segoe UI</FontFamily>
  <FontFamily x:Key="FontMono">Consolas</FontFamily>

  <!-- ══ Neón y luz ambiental ══════════════════════════════════════════════════
       El equivalente WPF del box-shadow en capas es DropShadowEffect con
       ShadowDepth=0: el desenfoque se reparte a los cuatro lados y queda un halo.

       Dos reglas que se respetan en todo el tema, porque «neón» degenera en ruido
       con una facilidad pasmosa:

       1. Brilla lo FOCAL, no todo: acción principal, foco del teclado, pestaña
          activa, progreso y el latido de trabajo en marcha. Nada más.
       2. JAMÁS dentro de una plantilla de fila. Cada Effect obliga a WPF a
          componer en una superficie intermedia; multiplicado por cientos de filas
          virtualizadas, el desplazamiento se vuelve pegajoso.
  -->
  <Color x:Key="c.glow">#968AE0</Color>

  <!-- Luz ambiental del fondo: dos manchas radiales muy tenues, una fría arriba a
       la izquierda y otra violeta abajo a la derecha. Son brochas, no efectos: no
       cuestan composición y dan la sensación de sala iluminada. -->
  <RadialGradientBrush x:Key="AmbienteA" Center="0.10,0.02" GradientOrigin="0.10,0.02"
                       RadiusX="0.62" RadiusY="0.95">
    <GradientStop Color="#40968AE0" Offset="0"/>
    <GradientStop Color="#14968AE0" Offset="0.45"/>
    <GradientStop Color="#00968AE0" Offset="1"/>
  </RadialGradientBrush>
  <RadialGradientBrush x:Key="AmbienteB" Center="0.92,1.0" GradientOrigin="0.92,1.0"
                       RadiusX="0.70" RadiusY="1.0">
    <GradientStop Color="#357C6BD8" Offset="0"/>
    <GradientStop Color="#0F7C6BD8" Offset="0.5"/>
    <GradientStop Color="#007C6BD8" Offset="1"/>
  </RadialGradientBrush>
  <!-- Un apunte de cian, al 6 %: es lo que separa «morado tintado» de «neón».
       Más alpha y empieza a pelearse con la marca. -->
  <RadialGradientBrush x:Key="AmbienteC" Center="0.72,0.06" GradientOrigin="0.72,0.06"
                       RadiusX="0.42" RadiusY="0.55">
    <GradientStop Color="#1A63D2E8" Offset="0"/>
    <GradientStop Color="#0063D2E8" Offset="1"/>
  </RadialGradientBrush>

  <!-- Halo suave reutilizable para elementos de marca (el logotipo). Congelado y
       compartido: no se anima, así que una sola instancia vale para todos. -->
  <DropShadowEffect x:Key="HaloMarca" ShadowDepth="0" BlurRadius="16" Color="#968AE0" Opacity="0.55"
                    RenderingBias="Performance"/>

  <!-- Superficie de panel translúcida (86 %). Deja que la luz ambiental atraviese en
       vez de recortarla: sin esto el fondo solo se ilumina en los márgenes y el centro
       de la ventana queda plano y apagado.
       Va aparte de «Surface» a propósito — los menús y los desplegables flotan sobre
       contenido cualquiera y ahí la translucidez se ve sucia; estos paneles siempre
       tienen detrás el fondo de la ventana. Con el texto a #E9E9ED el contraste se
       queda en torno a 12:1, muy por encima de AA. -->
  <SolidColorBrush x:Key="SurfaceGlass" Color="#DB232532"/>

  <!-- ══ Tooltip automático en el texto recortado ══
       Si algo acaba en puntos suspensivos, hay información escondida y hace falta poder
       leerla. Va como estilo implícito de TextBlock en lugar de repetir un ToolTip campo
       por campo: así lo hereda también lo que se añada mañana, que es donde se olvidaría.

       IsTextTrimmed solo se enciende cuando el texto SE HA recortado de verdad, así que
       no aparecen tooltips redundantes en lo que cabe entero. Y un ToolTip puesto a mano
       en el propio elemento gana a este, porque un valor local tiene más precedencia que
       un disparador de estilo — lo que permite seguir dando una explicación mejor que el
       propio texto donde interese. -->
  <Style x:Key="TextoRecortable" TargetType="TextBlock">
    <Style.Triggers>
      <!-- WPF no tiene «IsTextTrimmed» (eso es de UWP), así que el tooltip se pone en todo
           lo que PUEDE recortarse y se cancela al vuelo si el texto cabía entero. Esa
           comprobación vive en App, midiendo el texto sin tocar el layout. -->
      <Trigger Property="TextTrimming" Value="CharacterEllipsis">
        <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
      </Trigger>
      <Trigger Property="TextTrimming" Value="WordEllipsis">
        <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
      </Trigger>
    </Style.Triggers>
  </Style>
  <Style TargetType="TextBlock" BasedOn="{StaticResource TextoRecortable}"/>

  <!-- ══ Haz de borde ══════════════════════════════════════════════════════════
       Un destello corto que recorre el contorno, al estilo de «border-beam».

       El degradado va en el BORDE (BorderBrush), no en el fondo. La primera versión lo
       ponía de fondo y confiaba en que la capa de delante tapara el centro; en un control
       con fondo transparente —como la vista previa del prompt— no tapaba nada y el haz se
       veía atravesando el texto. Pintando el borde, el anillo es el anillo sea cual sea el
       relleno. El movimiento es una rotación de la brocha, que WPF anima en el hilo de
       composición: no repinta el control en cada fotograma.

       El degradado NO es un arcoíris repartido: son dos tramos transparentes con una
       banda clara estrecha en medio. Eso es lo que se lee como «un haz que pasa» en vez
       de como «un borde de colores».

       Es un ESTADO, no un adorno: con 55 botones en la app, encenderlo en todos sería el
       ruido que este proyecto lleva evitando desde el principio. Se reserva para el foco
       del teclado y para lo que está trabajando ahora mismo. -->
  <Duration x:Key="HazVuelta">0:0:2.8</Duration>

  <!-- Solo la geometría. La brocha va DENTRO de cada plantilla, nunca aquí: un Freezable
       declarado en un Setter se comparte entre todos los controles y WPF lo congela, así
       que animarlo lanza «Cannot animate on an immutable object instance» — un fallo que
       compila igual de bien y solo aparece al enfocar el primer campo. -->
  <Style x:Key="HazDeBorde" TargetType="Border">
    <Setter Property="Margin" Value="-1.5"/>
    <Setter Property="CornerRadius" Value="9.5"/>
    <Setter Property="BorderThickness" Value="1.5"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="IsHitTestVisible" Value="False"/>
    <Setter Property="Opacity" Value="0"/>
  </Style>

  <!-- Regla horizontal fundida en los extremos (firma Nocturne) -->
  <LinearGradientBrush x:Key="FadedRule" StartPoint="0,0" EndPoint="1,0">
    <GradientStop Color="#00E9E9ED" Offset="0"/>
    <GradientStop Color="#29E9E9ED" Offset="0.06"/>
    <GradientStop Color="#29E9E9ED" Offset="0.94"/>
    <GradientStop Color="#00E9E9ED" Offset="1"/>
  </LinearGradientBrush>

  <!-- ══ TextBox ══ -->
  <Style TargetType="TextBox">
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="CaretBrush" Value="{StaticResource Accent}"/>
    <Setter Property="Background" Value="{StaticResource Surface}"/>
    <Setter Property="BorderBrush" Value="{StaticResource Divider}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Grid>
            <!-- El haz va DETRÁS y sobresale: el borde opaco de delante tapa el centro y
                 deja solo el anillo a la vista. -->
            <Border x:Name="haz" Style="{StaticResource HazDeBorde}">
              <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                  <LinearGradientBrush.RelativeTransform>
                    <RotateTransform CenterX="0.5" CenterY="0.5"/>
                  </LinearGradientBrush.RelativeTransform>
                  <GradientStop Color="#00968AE0" Offset="0.00"/>
                  <GradientStop Color="#33968AE0" Offset="0.34"/>
                  <GradientStop Color="#FFD2CEFD" Offset="0.50"/>
                  <GradientStop Color="#33968AE0" Offset="0.66"/>
                  <GradientStop Color="#00968AE0" Offset="1.00"/>
                </LinearGradientBrush>
              </Border.BorderBrush>
            </Border>
            <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
              <!-- Halo de foco: aquí el neón no es adorno, señala dónde va a escribir
                   el teclado, que es justo lo que un borde fino de 1 px cuenta mal. -->
              <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="14" Color="{StaticResource c.glow}" Opacity="0"
                                  RenderingBias="Performance"/>
              </Border.Effect>
            </Border>
            <!-- El TEXTO va FUERA del borde con efecto: un Effect rasteriza a su subárbol en
                 una superficie intermedia y el texto pierde el ClearType — se veía borroso. -->
            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Neutral600}"/></Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}"/>
              <Trigger.EnterActions>
                <BeginStoryboard Name="sbFoco">
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="b"
                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                     To="0.45" Duration="0:0:0.15"/>
                    <DoubleAnimation Storyboard.TargetName="haz"
                                     Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18"/>
                    <!-- El giro solo corre mientras el campo tiene el foco: dejarlo girando
                         en los catorce campos de la app sería animación permanente a cambio
                         de nada. -->
                    <DoubleAnimation Storyboard.TargetName="haz"
                                     Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                     From="0" To="360" Duration="{StaticResource HazVuelta}"
                                     RepeatBehavior="Forever"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <StopStoryboard BeginStoryboardName="sbFoco"/>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="b"
                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                     To="0" Duration="0:0:0.22"/>
                    <DoubleAnimation Storyboard.TargetName="haz"
                                     Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.22"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ Campo con icono — UN solo sitio para Origen, Destino y Carpeta a organizar ══
       Estaba copiado a mano en tres pantallas, y por eso se quedó sin el haz de foco: el
       marco lo pintaba un Border de fuera, así que el haz del TextBox no tenía borde donde
       verse. Ahora el marco, el icono y el haz son del propio control. -->
  <Style TargetType="{x:Type local:CampoTexto}">
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="CaretBrush" Value="{StaticResource Accent}"/>
    <Setter Property="Background" Value="{StaticResource Surface}"/>
    <Setter Property="BorderBrush" Value="{StaticResource Divider}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="10,0"/>
    <Setter Property="Height" Value="34"/>
    <Setter Property="MinWidth" Value="110"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type local:CampoTexto}">
          <Grid>
            <Border x:Name="haz" Style="{StaticResource HazDeBorde}">
              <!-- La brocha se repite en cada plantilla en vez de salir de un recurso
                   común: un Freezable en un Setter se comparte y WPF lo congela, y
                   animarlo revienta al primer foco. -->
              <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                  <LinearGradientBrush.RelativeTransform>
                    <RotateTransform CenterX="0.5" CenterY="0.5"/>
                  </LinearGradientBrush.RelativeTransform>
                  <GradientStop Color="#00968AE0" Offset="0.00"/>
                  <GradientStop Color="#33968AE0" Offset="0.34"/>
                  <GradientStop Color="#FFD2CEFD" Offset="0.50"/>
                  <GradientStop Color="#33968AE0" Offset="0.66"/>
                  <GradientStop Color="#00968AE0" Offset="1.00"/>
                </LinearGradientBrush>
              </Border.BorderBrush>
            </Border>
            <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
              <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="14" Color="{StaticResource c.glow}" Opacity="0"
                                  RenderingBias="Performance"/>
              </Border.Effect>
            </Border>
            <!-- Contenido FUERA del borde con efecto: dentro, el Effect rasteriza el texto
                 y se veía borroso. -->
            <Grid Margin="{TemplateBinding Padding}">
              <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
              <Viewbox x:Name="icono" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center">
                <Path Data="{TemplateBinding Icono}" Stroke="{StaticResource Neutral500}"
                      StrokeThickness="1.4" StrokeLineJoin="Round"/>
              </Viewbox>
              <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" VerticalAlignment="Center"/>
            </Grid>
          </Grid>
          <ControlTemplate.Triggers>
            <!-- Sin icono no se reserva su hueco: el texto empieza donde el de un campo normal -->
            <Trigger Property="Icono" Value="{x:Null}">
              <Setter TargetName="icono" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Neutral600}"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}"/>
              <Trigger.EnterActions>
                <BeginStoryboard Name="sbFocoCampo">
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="b"
                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                     To="0.45" Duration="0:0:0.15"/>
                    <DoubleAnimation Storyboard.TargetName="haz"
                                     Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18"/>
                    <DoubleAnimation Storyboard.TargetName="haz"
                                     Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                     From="0" To="360" Duration="{StaticResource HazVuelta}"
                                     RepeatBehavior="Forever"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <StopStoryboard BeginStoryboardName="sbFocoCampo"/>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="b"
                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                     To="0" Duration="0:0:0.22"/>
                    <DoubleAnimation Storyboard.TargetName="haz"
                                     Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.22"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- TextBox sin marco (va DENTRO de un Border propio: Origen/Destino) -->
  <Style x:Key="InlineTextBox" TargetType="TextBox">
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="CaretBrush" Value="{StaticResource Accent}"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ Botones ══ -->
  <Style x:Key="BtnBase" TargetType="Button">
    <!-- Center por defecto, pero RESPETANDO a quien pida otra cosa: las listas de marcas y
         de idiomas piden Stretch y la plantilla se lo comía, así que salían dentadas. -->
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="12,7"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="FontWeight" Value="Medium"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid>
            <Border x:Name="haz" Style="{StaticResource HazDeBorde}" CornerRadius="9.5">
              <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                  <LinearGradientBrush.RelativeTransform>
                    <RotateTransform CenterX="0.5" CenterY="0.5"/>
                  </LinearGradientBrush.RelativeTransform>
                  <GradientStop Color="#00968AE0" Offset="0.00"/>
                  <GradientStop Color="#33968AE0" Offset="0.34"/>
                  <GradientStop Color="#FFD2CEFD" Offset="0.50"/>
                  <GradientStop Color="#33968AE0" Offset="0.66"/>
                  <GradientStop Color="#00968AE0" Offset="1.00"/>
                </LinearGradientBrush>
              </Border.BorderBrush>
            </Border>
            <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"/>
            </Border>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="b" Property="Opacity" Value="0.45"/></Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard Name="sbHaz">
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="haz" Storyboard.TargetProperty="Opacity"
                                     To="1" Duration="0:0:0.18"/>
                    <DoubleAnimation Storyboard.TargetName="haz"
                                     Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                     From="0" To="360" Duration="{StaticResource HazVuelta}" RepeatBehavior="Forever"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <StopStoryboard BeginStoryboardName="sbHaz"/>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="haz" Storyboard.TargetProperty="Opacity"
                                     To="0" Duration="0:0:0.22"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- La acción principal es el único botón que se enciende, y solo al apuntarlo:
       un neón permanente en cada botón deja de señalar nada. El halo entra en
       150 ms y sale en 220 ms — se apaga más despacio de lo que prende, que es
       como se comporta algo que de verdad brilla. -->
  <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
    <Setter Property="Foreground" Value="{StaticResource Accent}"/>
    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid>
            <Border x:Name="haz" Style="{StaticResource HazDeBorde}" CornerRadius="9.5">
              <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                  <LinearGradientBrush.RelativeTransform>
                    <RotateTransform CenterX="0.5" CenterY="0.5"/>
                  </LinearGradientBrush.RelativeTransform>
                  <GradientStop Color="#00968AE0" Offset="0.00"/>
                  <GradientStop Color="#33968AE0" Offset="0.34"/>
                  <GradientStop Color="#FFD2CEFD" Offset="0.50"/>
                  <GradientStop Color="#33968AE0" Offset="0.66"/>
                  <GradientStop Color="#00968AE0" Offset="1.00"/>
                </LinearGradientBrush>
              </Border.BorderBrush>
            </Border>
          <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8"
                  Padding="{TemplateBinding Padding}">
            <!-- El efecto se declara aquí dentro, no como recurso compartido: cada
                 botón necesita su propia instancia para poder animarla por separado. -->
            <Border.Effect>
              <DropShadowEffect ShadowDepth="0" BlurRadius="18" Color="{StaticResource c.glow}" Opacity="0"
                                RenderingBias="Performance"/>
            </Border.Effect>
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"/>
          </Border>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard Name="sbHazPri">
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="haz" Storyboard.TargetProperty="Opacity"
                                     To="1" Duration="0:0:0.18"/>
                    <DoubleAnimation Storyboard.TargetName="haz"
                                     Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                     From="0" To="360" Duration="{StaticResource HazVuelta}" RepeatBehavior="Forever"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <StopStoryboard BeginStoryboardName="sbHazPri"/>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="haz" Storyboard.TargetProperty="Opacity"
                                     To="0" Duration="0:0:0.22"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="b" Property="Background" Value="{StaticResource HoverPrimary}"/>
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="b"
                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                     To="0.55" Duration="0:0:0.15"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="b"
                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                     To="0" Duration="0:0:0.22"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="b" Property="Background" Value="{StaticResource PressedPrimary}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="b" Property="Opacity" Value="0.45"/></Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
    <Setter Property="BorderBrush" Value="{StaticResource Divider}"/>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#14E9E9ED"/></Trigger>
      <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="#24E9E9ED"/></Trigger>
    </Style.Triggers>
  </Style>

  <!-- Botón que flota SOBRE contenido (las tarjetas de catálogo): fondo OPACO con
       acabado de cristal — degradado sutil y brillo en el canto superior. Los normales
       heredan fondo transparente, y encima de un texto se leía el texto a través. -->
  <Style x:Key="BtnCristal" TargetType="Button" BasedOn="{StaticResource BtnBase}">
    <Setter Property="BorderBrush" Value="#3DE9E9ED"/>
    <Setter Property="Background">
      <Setter.Value>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
          <GradientStop Color="#FF34364A" Offset="0"/>
          <GradientStop Color="#FF262838" Offset="1"/>
        </LinearGradientBrush>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background">
          <Setter.Value>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
              <GradientStop Color="#FF3E4157" Offset="0"/>
              <GradientStop Color="#FF2C2E40" Offset="1"/>
            </LinearGradientBrush>
          </Setter.Value>
        </Setter>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource BtnBase}">
    <Setter Property="Foreground" Value="{StaticResource Accent}"/>
    <Setter Property="Padding" Value="6,4"/>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#1A968AE0"/></Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="BtnGhostMuted" TargetType="Button" BasedOn="{StaticResource BtnGhost}">
    <Setter Property="Foreground" Value="{StaticResource Neutral400}"/>
    <Setter Property="FontWeight" Value="Normal"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>

  <!-- Botón de la barra de título (min/max/close) -->
  <Style x:Key="BtnTitle" TargetType="Button" BasedOn="{StaticResource BtnBase}">
    <Setter Property="Foreground" Value="{StaticResource Neutral500}"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Width" Value="34"/><Setter Property="Height" Value="26"/>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="#14E9E9ED"/><Setter Property="Foreground" Value="{StaticResource Text}"/>
      </Trigger>
    </Style.Triggers>
  </Style>
  <Style x:Key="BtnClose" TargetType="Button" BasedOn="{StaticResource BtnTitle}">
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="#C0392B"/><Setter Property="Foreground" Value="White"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- ══ ComboBox ══ -->
  <ControlTemplate x:Key="ComboToggle" TargetType="ToggleButton">
    <Border x:Name="b" Background="{StaticResource Field}" BorderBrush="{StaticResource Divider}" BorderThickness="1" CornerRadius="8"/>
    <ControlTemplate.Triggers>
      <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Neutral600}"/></Trigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>
  <Style TargetType="ComboBox">
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Height" Value="32"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBox">
          <Grid>
            <Border x:Name="haz" Style="{StaticResource HazDeBorde}" CornerRadius="9.5">
              <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                  <LinearGradientBrush.RelativeTransform>
                    <RotateTransform CenterX="0.5" CenterY="0.5"/>
                  </LinearGradientBrush.RelativeTransform>
                  <GradientStop Color="#00968AE0" Offset="0.00"/>
                  <GradientStop Color="#33968AE0" Offset="0.34"/>
                  <GradientStop Color="#FFD2CEFD" Offset="0.50"/>
                  <GradientStop Color="#33968AE0" Offset="0.66"/>
                  <GradientStop Color="#00968AE0" Offset="1.00"/>
                </LinearGradientBrush>
              </Border.BorderBrush>
            </Border>
            <ToggleButton Focusable="False" Template="{StaticResource ComboToggle}"
                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
            <ContentPresenter x:Name="cp" Content="{TemplateBinding SelectionBoxItem}"
                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                              Margin="10,0,26,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
            <TextBox x:Name="PART_EditableTextBox" Margin="8,0,26,0" VerticalAlignment="Center"
                     Background="Transparent" BorderThickness="0" Foreground="{StaticResource Text}"
                     CaretBrush="{StaticResource Accent}" Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}">
              <TextBox.Template>
                <ControlTemplate TargetType="TextBox"><ScrollViewer x:Name="PART_ContentHost"/></ControlTemplate>
              </TextBox.Template>
            </TextBox>
            <Path Data="M3.5,6 L8,10.5 L12.5,6" Stroke="{StaticResource Neutral500}" StrokeThickness="1.6"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                  HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" IsHitTestVisible="False"/>
            <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom"
                   IsOpen="{TemplateBinding IsDropDownOpen}" Focusable="False" PopupAnimation="Slide">
              <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Neutral800}" BorderThickness="1"
                      CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}" Margin="0,4,0,0" Padding="4">
                <ScrollViewer MaxHeight="260"><ItemsPresenter/></ScrollViewer>
              </Border>
            </Popup>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard Name="sbHazCombo">
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="haz" Storyboard.TargetProperty="Opacity"
                                     To="1" Duration="0:0:0.18"/>
                    <DoubleAnimation Storyboard.TargetName="haz"
                                     Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                     From="0" To="360" Duration="{StaticResource HazVuelta}" RepeatBehavior="Forever"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <StopStoryboard BeginStoryboardName="sbHazCombo"/>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="haz" Storyboard.TargetProperty="Opacity"
                                     To="0" Duration="0:0:0.22"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsEditable" Value="True">
              <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
              <Setter TargetName="cp" Property="Visibility" Value="Hidden"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style TargetType="ComboBoxItem">
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Padding" Value="8,6"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBoxItem">
          <Border x:Name="b" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
            <ContentPresenter/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True"><Setter TargetName="b" Property="Background" Value="{StaticResource Accent900}"/></Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ CheckBox (opciones) ══ -->
  <Style TargetType="CheckBox">
    <Setter Property="Foreground" Value="{StaticResource Neutral400}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <StackPanel Orientation="Horizontal" Background="Transparent">
            <Grid VerticalAlignment="Center">
              <Border x:Name="haz" Style="{StaticResource HazDeBorde}" CornerRadius="6">
                <Border.BorderBrush>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <LinearGradientBrush.RelativeTransform>
                      <RotateTransform CenterX="0.5" CenterY="0.5"/>
                    </LinearGradientBrush.RelativeTransform>
                    <GradientStop Color="#00968AE0" Offset="0.00"/>
                    <GradientStop Color="#33968AE0" Offset="0.34"/>
                    <GradientStop Color="#FFD2CEFD" Offset="0.50"/>
                    <GradientStop Color="#33968AE0" Offset="0.66"/>
                    <GradientStop Color="#00968AE0" Offset="1.00"/>
                  </LinearGradientBrush>
                </Border.BorderBrush>
              </Border>
            <Border x:Name="box" Width="15" Height="15" CornerRadius="4" BorderThickness="1.5"
                    BorderBrush="{StaticResource Divider}" Background="Transparent" VerticalAlignment="Center">
              <Path x:Name="tick" Data="M2,5 L6,9 L12,2" Stroke="{StaticResource Accent200}" StrokeThickness="1.6"
                    StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Visibility="Collapsed"/>
            </Border>
            </Grid>
            <ContentPresenter Margin="7,0,0,0" VerticalAlignment="Center"/>
          </StackPanel>
          <ControlTemplate.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard Name="sbHazChk">
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="haz" Storyboard.TargetProperty="Opacity"
                                     To="1" Duration="0:0:0.18"/>
                    <DoubleAnimation Storyboard.TargetName="haz"
                                     Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.RelativeTransform).(RotateTransform.Angle)"
                                     From="0" To="360" Duration="{StaticResource HazVuelta}" RepeatBehavior="Forever"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <StopStoryboard BeginStoryboardName="sbHazChk"/>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="haz" Storyboard.TargetProperty="Opacity"
                                     To="0" Duration="0:0:0.22"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Accent}"/>
              <Setter TargetName="box" Property="Background" Value="{StaticResource Accent800}"/>
              <Setter TargetName="tick" Property="Visibility" Value="Visible"/>
              <Setter Property="Foreground" Value="{StaticResource Text}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Accent}"/></Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ ProgressBar ══ -->
  <Style TargetType="ProgressBar">
    <Setter Property="Height" Value="6"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ProgressBar">
          <Border Background="{StaticResource Field}" CornerRadius="3">
            <Grid>
              <Border x:Name="PART_Track"/>
              <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#796CBF" Offset="0"/><GradientStop Color="#B5ABFC" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
                <!-- La barra de progreso deja un rastro de luz sobre el canal: el
                     avance se lee de reojo, sin tener que mirar el número. Late muy
                     despacio (2,6 s) para que sugiera actividad sin distraer de la
                     tarea que se está haciendo mientras. -->
                <Border.Effect>
                  <DropShadowEffect ShadowDepth="0" BlurRadius="12" Color="{StaticResource c.glow}" Opacity="0.5"
                                    RenderingBias="Performance"/>
                </Border.Effect>
                <Border.Triggers>
                  <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                         From="9" To="17" Duration="0:0:2.6" AutoReverse="True"
                                         RepeatBehavior="Forever"/>
                      </Storyboard>
                    </BeginStoryboard>
                  </EventTrigger>
                </Border.Triggers>
              </Border>
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ ListView / tabla ══ -->
  <Style x:Key="ColHeader" TargetType="GridViewColumnHeader">
    <Setter Property="Foreground" Value="#99E9E9ED"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="Padding" Value="8,6"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="GridViewColumnHeader">
          <Border Background="Transparent" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="RowStyle" TargetType="ListViewItem">
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListViewItem">
          <Border x:Name="strip" BorderBrush="Transparent" BorderThickness="2,0,0,0" Background="Transparent">
            <Border x:Name="fill" Background="Transparent">
              <GridViewRowPresenter VerticalAlignment="Center" Margin="0,7"/>
            </Border>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="fill" Property="Background" Value="{StaticResource RowHover}"/></Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="fill" Property="Background" Value="{StaticResource RowSelected}"/>
              <Setter TargetName="strip" Property="BorderBrush" Value="{StaticResource Accent}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="TableView" TargetType="ListView">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="ItemContainerStyle" Value="{StaticResource RowStyle}"/>
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
    <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
  </Style>

  <!-- ══ ScrollBar (oscuro, minimalista, vertical y horizontal) ══ -->
  <Style x:Key="ScrollThumbV" TargetType="Thumb">
    <Setter Property="Template"><Setter.Value>
      <ControlTemplate TargetType="Thumb"><Border Background="{StaticResource Neutral700}" CornerRadius="4" Margin="2,0"/></ControlTemplate>
    </Setter.Value></Setter>
  </Style>
  <Style x:Key="ScrollThumbH" TargetType="Thumb">
    <Setter Property="Template"><Setter.Value>
      <ControlTemplate TargetType="Thumb"><Border Background="{StaticResource Neutral700}" CornerRadius="4" Margin="0,2"/></ControlTemplate>
    </Setter.Value></Setter>
  </Style>
  <Style x:Key="ScrollNoop" TargetType="RepeatButton">
    <Setter Property="Opacity" Value="0"/>
    <Setter Property="Focusable" Value="False"/>
    <Setter Property="IsTabStop" Value="False"/>
    <Setter Property="Template">
      <Setter.Value><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></Setter.Value>
    </Setter>
  </Style>
  <ControlTemplate x:Key="VScroll" TargetType="ScrollBar">
    <Grid Background="Transparent">
      <Track x:Name="PART_Track" IsDirectionReversed="True">
        <Track.DecreaseRepeatButton><RepeatButton Style="{StaticResource ScrollNoop}" Command="ScrollBar.PageUpCommand"/></Track.DecreaseRepeatButton>
        <Track.Thumb><Thumb Style="{StaticResource ScrollThumbV}"/></Track.Thumb>
        <Track.IncreaseRepeatButton><RepeatButton Style="{StaticResource ScrollNoop}" Command="ScrollBar.PageDownCommand"/></Track.IncreaseRepeatButton>
      </Track>
    </Grid>
  </ControlTemplate>
  <ControlTemplate x:Key="HScroll" TargetType="ScrollBar">
    <Grid Background="Transparent">
      <Track x:Name="PART_Track">
        <Track.DecreaseRepeatButton><RepeatButton Style="{StaticResource ScrollNoop}" Command="ScrollBar.PageLeftCommand"/></Track.DecreaseRepeatButton>
        <Track.Thumb><Thumb Style="{StaticResource ScrollThumbH}"/></Track.Thumb>
        <Track.IncreaseRepeatButton><RepeatButton Style="{StaticResource ScrollNoop}" Command="ScrollBar.PageRightCommand"/></Track.IncreaseRepeatButton>
      </Track>
    </Grid>
  </ControlTemplate>
  <Style TargetType="ScrollBar">
    <Setter Property="Background" Value="Transparent"/>
    <Style.Triggers>
      <Trigger Property="Orientation" Value="Vertical">
        <Setter Property="Width" Value="10"/>
        <Setter Property="Template" Value="{StaticResource VScroll}"/>
      </Trigger>
      <Trigger Property="Orientation" Value="Horizontal">
        <Setter Property="Height" Value="10"/>
        <Setter Property="Template" Value="{StaticResource HScroll}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- ══ Slider tipo línea de tiempo (previsualización) ══ -->
  <Style x:Key="TimelineSlider" TargetType="Slider">
    <Setter Property="Height" Value="24"/>
    <Setter Property="IsMoveToPointEnabled" Value="True"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Slider">
          <Grid>
            <Border Height="18" CornerRadius="4" Background="{StaticResource Field}" BorderBrush="{StaticResource Neutral800}" BorderThickness="1" VerticalAlignment="Center"/>
            <Track x:Name="PART_Track">
              <Track.DecreaseRepeatButton>
                <RepeatButton Command="Slider.DecreaseLarge">
                  <RepeatButton.Template>
                    <ControlTemplate TargetType="RepeatButton"><Border Height="18" CornerRadius="4,0,0,4" Background="#33968AE0" VerticalAlignment="Center"/></ControlTemplate>
                  </RepeatButton.Template>
                </RepeatButton>
              </Track.DecreaseRepeatButton>
              <Track.IncreaseRepeatButton>
                <RepeatButton Command="Slider.IncreaseLarge">
                  <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template>
                </RepeatButton>
              </Track.IncreaseRepeatButton>
              <Track.Thumb>
                <Thumb>
                  <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                      <Grid Width="12" Background="Transparent">
                        <Rectangle Width="2" Fill="{StaticResource Accent}" HorizontalAlignment="Center"/>
                        <Border Width="11" Height="11" CornerRadius="6" Background="{StaticResource Accent}" VerticalAlignment="Top"/>
                        <Border Width="11" Height="11" CornerRadius="6" Background="{StaticResource Accent}" VerticalAlignment="Bottom"/>
                      </Grid>
                    </ControlTemplate>
                  </Thumb.Template>
                </Thumb>
              </Track.Thumb>
            </Track>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ Chip de idioma (píldora) ══ -->
  <Style x:Key="ChipStyle" TargetType="CheckBox">
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Margin" Value="0,0,6,0"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="11.5"/>
    <Setter Property="Foreground" Value="{StaticResource Neutral500}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <Border x:Name="b" CornerRadius="6" BorderThickness="1" BorderBrush="{StaticResource Divider}" Background="Transparent" Padding="10,3">
            <StackPanel Orientation="Horizontal">
              <TextBlock x:Name="tick" Text="✓" FontSize="10" Margin="0,0,4,0" Foreground="{StaticResource Accent200}" Visibility="Collapsed" VerticalAlignment="Center"/>
              <ContentPresenter VerticalAlignment="Center"/>
            </StackPanel>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="b" Property="Background" Value="{StaticResource Accent900}"/>
              <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent700}"/>
              <Setter TargetName="tick" Property="Visibility" Value="Visible"/>
              <Setter Property="Foreground" Value="{StaticResource Accent200}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ Barra de menú (oscura) ══ -->
  <Style TargetType="Menu">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Foreground" Value="{StaticResource Neutral400}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="12.5"/>
  </Style>

  <!-- Menú contextual: sin esto WPF pinta el panel claro del sistema -->
  <Style TargetType="ContextMenu">
    <Setter Property="Foreground" Value="{StaticResource Neutral300}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="HasDropShadow" Value="False"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ContextMenu">
          <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Divider}" BorderThickness="1"
                  CornerRadius="10" Padding="6" Margin="12" SnapsToDevicePixels="True" UseLayoutRounding="True">
            <Border.Effect><DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.45" Color="#000000"/></Border.Effect>
            <ItemsPresenter/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Separador de menú: WPF lo busca por SeparatorStyleKey (sin esto usa el clásico gris) -->
  <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="Separator">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Separator">
          <Border Height="1" Background="{StaticResource MenuSeparator}" Margin="10,5" SnapsToDevicePixels="True"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style TargetType="Separator" BasedOn="{StaticResource {x:Static MenuItem.SeparatorStyleKey}}"/>

  <Style TargetType="MenuItem">
    <Setter Property="Foreground" Value="{StaticResource Neutral300}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Padding" Value="10,7"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="MenuItem">
          <Border x:Name="wrap" Background="Transparent" CornerRadius="6" Margin="{TemplateBinding Margin}"
                  BorderBrush="Transparent" BorderThickness="3,0,0,0"
                  Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True" UseLayoutRounding="True">
            <Grid VerticalAlignment="Center">
              <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="colChk" Width="18"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="chk" Grid.Column="0" Text="✓" FontSize="11" VerticalAlignment="Center"
                         Foreground="{StaticResource Accent300}" Visibility="Collapsed"/>
              <ContentPresenter x:Name="hdr" Grid.Column="1" ContentSource="Header"
                                VerticalAlignment="Center" RecognizesAccessKey="True"/>
              <TextBlock x:Name="gesture" Grid.Column="2" Text="{TemplateBinding InputGestureText}"
                         FontSize="11" Margin="26,0,0,0" VerticalAlignment="Center"
                         Foreground="{StaticResource MenuGesture}"/>
              <Path x:Name="arrow" Grid.Column="3" Data="M0,0 L4,4 L0,8" Stroke="{StaticResource MenuGesture}"
                    StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                    Margin="18,0,2,0" VerticalAlignment="Center" Visibility="Collapsed"/>
              <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False" IsOpen="{TemplateBinding IsSubmenuOpen}"
                     Placement="Bottom" HorizontalOffset="-6" VerticalOffset="6" PopupAnimation="Fade">
                <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Divider}" BorderThickness="1"
                        CornerRadius="10" Padding="6" MinWidth="210" Margin="10,2,14,14"
                        SnapsToDevicePixels="True" UseLayoutRounding="True">
                  <Border.Effect><DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.45" Color="#000000"/></Border.Effect>
                  <ItemsPresenter/>
                </Border>
              </Popup>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <!-- barra superior: sin columna del ✓ (el texto queda centrado de verdad) -->
            <Trigger Property="Role" Value="TopLevelHeader">
              <Setter TargetName="colChk" Property="Width" Value="0"/>
              <Setter Property="Padding" Value="13,6"/>
              <Setter Property="Margin" Value="2,0"/>
            </Trigger>
            <Trigger Property="Role" Value="TopLevelItem">
              <Setter TargetName="colChk" Property="Width" Value="0"/>
              <Setter Property="Padding" Value="13,6"/>
              <Setter Property="Margin" Value="2,0"/>
            </Trigger>
            <Trigger Property="Role" Value="SubmenuItem">
              <Setter Property="Margin" Value="0,1"/>
            </Trigger>
            <Trigger Property="Role" Value="SubmenuHeader">
              <Setter Property="Margin" Value="0,1"/>
              <Setter TargetName="arrow" Property="Visibility" Value="Visible"/>
              <Setter TargetName="PART_Popup" Property="Placement" Value="Right"/>
              <Setter TargetName="PART_Popup" Property="HorizontalOffset" Value="2"/>
              <Setter TargetName="PART_Popup" Property="VerticalOffset" Value="-8"/>
            </Trigger>
            <Trigger Property="IsHighlighted" Value="True">
              <Setter TargetName="wrap" Property="Background" Value="{StaticResource MenuHighlight}"/>
              <Setter TargetName="wrap" Property="BorderBrush" Value="{StaticResource Accent300}"/>
              <Setter Property="Foreground" Value="{StaticResource Text}"/>
              <Setter TargetName="arrow" Property="Stroke" Value="{StaticResource Text}"/>
              <Setter TargetName="gesture" Property="Foreground" Value="{StaticResource Accent200}"/>
            </Trigger>
            <!-- la barra superior resalta en neutro, no en morado -->
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="Role" Value="TopLevelHeader"/>
                <Condition Property="IsHighlighted" Value="True"/>
              </MultiTrigger.Conditions>
              <Setter TargetName="wrap" Property="Background" Value="{StaticResource PressedPrimary}"/>
              <Setter Property="Foreground" Value="{StaticResource Text}"/>
            </MultiTrigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="Role" Value="TopLevelHeader"/>
                <Condition Property="IsSubmenuOpen" Value="True"/>
              </MultiTrigger.Conditions>
              <Setter TargetName="wrap" Property="Background" Value="{StaticResource PressedPrimary}"/>
              <Setter Property="Foreground" Value="{StaticResource Text}"/>
            </MultiTrigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="chk" Property="Visibility" Value="Visible"/>
            </Trigger>
            <!-- deshabilitado: color propio en vez de opacidad, que hundía el contraste a ~2:1 -->
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{StaticResource MenuDisabled}"/>
              <Setter TargetName="gesture" Property="Foreground" Value="{StaticResource MenuDisabled}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ TabControl / TabItem (oscuro, subrayado accent) ══ -->
  <Style TargetType="TabControl">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabControl">
          <DockPanel>
            <Border DockPanel.Dock="Top" BorderBrush="{StaticResource Divider}" BorderThickness="0,0,0,1">
              <TabPanel IsItemsHost="True" Panel.ZIndex="1" Margin="0" Background="Transparent"/>
            </Border>
            <ContentPresenter ContentSource="SelectedContent" Margin="0,14,0,0"/>
          </DockPanel>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="TabItem">
    <Setter Property="Foreground" Value="{StaticResource Neutral500}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabItem">
          <Border x:Name="b" BorderBrush="Transparent" BorderThickness="0,0,0,2" Padding="12,7" Margin="0,0,4,0">
            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Foreground" Value="{StaticResource Neutral300}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}"/>
              <Setter Property="Foreground" Value="{StaticResource Accent300}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ ToolTip (oscuro, legible, con sombra) ══ -->
  <Style TargetType="ToolTip">
    <Setter Property="Foreground" Value="{StaticResource Neutral300}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="11.5"/>
    <Setter Property="Placement" Value="Bottom"/>
    <Setter Property="VerticalOffset" Value="7"/>
    <Setter Property="HasDropShadow" Value="False"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToolTip">
          <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Divider}" BorderThickness="1"
                  CornerRadius="8" Padding="11,8" MaxWidth="330" Margin="6" SnapsToDevicePixels="True">
            <Border.Effect><DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.45" Color="#000000"/></Border.Effect>
            <ContentPresenter>
              <ContentPresenter.Resources>
                <!-- el texto plano del ToolTip se ajusta en varias líneas -->
                <DataTemplate DataType="{x:Type sys:String}">
                  <TextBlock Text="{Binding}" TextWrapping="Wrap" LineHeight="16.5"
                             LineStackingStrategy="BlockLineHeight"/>
                </DataTemplate>
              </ContentPresenter.Resources>
            </ContentPresenter>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ Elemento del desplegable de autocompletado ══ -->
  <Style x:Key="SuggestItem" TargetType="ListBoxItem">
    <Setter Property="Padding" Value="8,5"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListBoxItem">
          <Border x:Name="b" Background="Transparent" CornerRadius="5" Padding="{TemplateBinding Padding}">
            <ContentPresenter/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="b" Property="Background" Value="{StaticResource RowHover}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="b" Property="Background" Value="{StaticResource Accent900}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ RadioButton (oscuro) ══ -->
  <Style TargetType="RadioButton">
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Margin" Value="0,4"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <StackPanel Orientation="Horizontal" Background="Transparent">
            <Grid Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0">
              <Ellipse x:Name="ring" Stroke="{StaticResource Neutral600}" StrokeThickness="1.5"/>
              <Ellipse x:Name="dot" Width="8" Height="8" Fill="{StaticResource Accent}" Visibility="Collapsed"/>
            </Grid>
            <ContentPresenter VerticalAlignment="Center"/>
          </StackPanel>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="ring" Property="Stroke" Value="{StaticResource Accent400}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="ring" Property="Stroke" Value="{StaticResource Accent}"/>
              <Setter TargetName="dot" Property="Visibility" Value="Visible"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>


  <!-- Reproduccion de video: las usan el reproductor en modo focus y la pagina
       de Recortes. Viven aqui para que ver un video y marcar un corte se sientan
       igual: si el punto de la barra cambia en un sitio, cambia en los dos. -->
    <!-- El acento recorre la parte ya vista: morado donde empezó, cian en el punto de
         reproducción. Da sensación de avance sin necesidad de animar nada. -->
    <LinearGradientBrush x:Key="Recorrido" StartPoint="0,0" EndPoint="1,0">
      <GradientStop Color="#968AE0" Offset="0"/>
      <GradientStop Color="#63D2E8" Offset="1"/>
    </LinearGradientBrush>

    <!-- ══ Barra de posición ══
         Riel de 3 px y punto blanco de 11 que crece al pasar por encima. El área de
         click son 18 px: el riel fino es para mirarlo, no para acertarle con el ratón. -->
    <Style x:Key="BarraVideo" TargetType="Slider">
      <Setter Property="IsMoveToPointEnabled" Value="True"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Height" Value="18"/>
      <Setter Property="Focusable" Value="False"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Slider">
            <Grid Background="Transparent">
              <Border Height="3" CornerRadius="2" Background="#2EFFFFFF" VerticalAlignment="Center"/>
              <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                    <RepeatButton.Template>
                      <ControlTemplate TargetType="RepeatButton">
                        <Border Height="3" CornerRadius="2" VerticalAlignment="Center"
                                Background="{StaticResource Recorrido}"/>
                      </ControlTemplate>
                    </RepeatButton.Template>
                  </RepeatButton>
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                    <RepeatButton.Template>
                      <ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate>
                    </RepeatButton.Template>
                  </RepeatButton>
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                  <Thumb Focusable="False">
                    <Thumb.Template>
                      <ControlTemplate TargetType="Thumb">
                        <Grid Width="18" Height="18" Background="Transparent">
                          <Ellipse x:Name="bola" Width="11" Height="11" Fill="White"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bola" Property="Width" Value="15"/>
                            <Setter TargetName="bola" Property="Height" Value="15"/>
                          </Trigger>
                          <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="bola" Property="Width" Value="15"/>
                            <Setter TargetName="bola" Property="Height" Value="15"/>
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ══ Volumen ══ mismo lenguaje, en pequeño -->
    <Style x:Key="BarraVolumen" TargetType="Slider" BasedOn="{StaticResource BarraVideo}">
      <Setter Property="Height" Value="16"/>
      <Setter Property="Width" Value="74"/>
    </Style>

    <!-- ══ Botón de icono ══ el círculo de fondo solo aparece al pasar por encima -->
    <Style x:Key="BtnIcono" TargetType="Button">
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Focusable" Value="False"/>
      <Setter Property="Foreground" Value="#E4E6F2"/>
      <Setter Property="Width" Value="34"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Grid Background="Transparent">
              <Ellipse x:Name="fondo" Fill="#1FFFFFFF" Opacity="0"/>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="fondo" Property="Opacity" Value="1"/>
                <Setter Property="Foreground" Value="White"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="fondo" Property="Fill" Value="#33FFFFFF"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ══ Botón grande de reproducir ══
         El aro degradado es el único elemento de color fuerte de la ventana: marca
         dónde está la acción principal sin necesidad de más adornos. -->
    <Style x:Key="BtnPlay" TargetType="Button">
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Focusable" Value="False"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Grid Width="48" Height="48" Background="Transparent">
              <Ellipse x:Name="aro" StrokeThickness="2.2" Stroke="{StaticResource Recorrido}"/>
              <Ellipse x:Name="relleno" Margin="2.5" Fill="#1AFFFFFF" Opacity="0"/>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="relleno" Property="Opacity" Value="1"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="relleno" Property="Fill" Value="#2EFFFFFF"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

</ResourceDictionary>
