<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

  <!-- ══ Nocturne — tokens (de Claude Design) ══ -->
  <Color x:Key="c.bg">#161826</Color>
  <Color x:Key="c.surface">#232532</Color>
  <Color x:Key="c.field">#292B31</Color>
  <Color x:Key="c.text">#E9E9ED</Color>
  <Color x:Key="c.accent">#968AE0</Color>

  <SolidColorBrush x:Key="Bg" Color="#161826"/>
  <SolidColorBrush x:Key="Surface" Color="#232532"/>
  <SolidColorBrush x:Key="Field" Color="#292B31"/>
  <SolidColorBrush x:Key="Text" Color="#E9E9ED"/>
  <SolidColorBrush x:Key="Neutral300" Color="#CFD3E5"/>
  <SolidColorBrush x:Key="Neutral400" Color="#B2B6CA"/>
  <SolidColorBrush x:Key="Neutral500" Color="#9397AB"/>
  <SolidColorBrush x:Key="Neutral600" Color="#75798C"/>
  <SolidColorBrush x:Key="Neutral700" Color="#595D6C"/>
  <SolidColorBrush x:Key="Neutral800" Color="#3F424D"/>
  <SolidColorBrush x:Key="Divider" Color="#29E9E9ED"/>
  <SolidColorBrush x:Key="Accent" Color="#968AE0"/>
  <SolidColorBrush x:Key="Accent200" Color="#E7E5FE"/>
  <SolidColorBrush x:Key="Accent300" Color="#D2CEFD"/>
  <SolidColorBrush x:Key="Accent400" Color="#B5ABFC"/>
  <SolidColorBrush x:Key="Accent600" Color="#796CBF"/>
  <SolidColorBrush x:Key="Accent700" Color="#5D5294"/>
  <SolidColorBrush x:Key="Accent800" Color="#423A6A"/>
  <SolidColorBrush x:Key="Accent900" Color="#2B2741"/>
  <SolidColorBrush x:Key="HoverPrimary" Color="#25263C"/>
  <SolidColorBrush x:Key="PressedPrimary" Color="#333250"/>
  <SolidColorBrush x:Key="RowSelected" Color="#232338"/>
  <SolidColorBrush x:Key="RowHover" Color="#1F2130"/>

  <!-- Menús: contrastes comprobados sobre Surface (#232532).
       MenuHighlight 2,2:1 frente al panel (el resalte antiguo, Accent900, daba 1,06:1
       y era casi invisible) y 5,6:1 con el texto → AA. MenuGesture 5,3:1 (antes 3,5:1,
       fallaba AA). MenuDisabled 3,5:1: legible pero claramente apagado. -->
  <SolidColorBrush x:Key="MenuHighlight" Color="#5D5294"/>
  <SolidColorBrush x:Key="MenuGesture" Color="#9397AB"/>
  <SolidColorBrush x:Key="MenuDisabled" Color="#75798C"/>
  <SolidColorBrush x:Key="MenuSeparator" Color="#3A3E4E"/>

  <FontFamily x:Key="FontUI">Segoe UI</FontFamily>
  <FontFamily x:Key="FontMono">Consolas</FontFamily>

  <!-- Regla horizontal fundida en los extremos (firma Nocturne) -->
  <LinearGradientBrush x:Key="FadedRule" StartPoint="0,0" EndPoint="1,0">
    <GradientStop Color="#00E9E9ED" Offset="0"/>
    <GradientStop Color="#29E9E9ED" Offset="0.06"/>
    <GradientStop Color="#29E9E9ED" Offset="0.94"/>
    <GradientStop Color="#00E9E9ED" Offset="1"/>
  </LinearGradientBrush>

  <!-- ══ TextBox ══ -->
  <Style TargetType="TextBox">
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="CaretBrush" Value="{StaticResource Accent}"/>
    <Setter Property="Background" Value="{StaticResource Surface}"/>
    <Setter Property="BorderBrush" Value="{StaticResource Divider}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Neutral600}"/></Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}"/></Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- TextBox sin marco (va DENTRO de un Border propio: Origen/Destino) -->
  <Style x:Key="InlineTextBox" TargetType="TextBox">
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="CaretBrush" Value="{StaticResource Accent}"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ Botones ══ -->
  <Style x:Key="BtnBase" TargetType="Button">
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="12,7"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="FontWeight" Value="Medium"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="b" Property="Opacity" Value="0.45"/></Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
    <Setter Property="Foreground" Value="{StaticResource Accent}"/>
    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{StaticResource HoverPrimary}"/></Trigger>
      <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="{StaticResource PressedPrimary}"/></Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
    <Setter Property="BorderBrush" Value="{StaticResource Divider}"/>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#14E9E9ED"/></Trigger>
      <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="#24E9E9ED"/></Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource BtnBase}">
    <Setter Property="Foreground" Value="{StaticResource Accent}"/>
    <Setter Property="Padding" Value="6,4"/>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#1A968AE0"/></Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="BtnGhostMuted" TargetType="Button" BasedOn="{StaticResource BtnGhost}">
    <Setter Property="Foreground" Value="{StaticResource Neutral400}"/>
    <Setter Property="FontWeight" Value="Normal"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>

  <!-- Botón de la barra de título (min/max/close) -->
  <Style x:Key="BtnTitle" TargetType="Button" BasedOn="{StaticResource BtnBase}">
    <Setter Property="Foreground" Value="{StaticResource Neutral500}"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Width" Value="34"/><Setter Property="Height" Value="26"/>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="#14E9E9ED"/><Setter Property="Foreground" Value="{StaticResource Text}"/>
      </Trigger>
    </Style.Triggers>
  </Style>
  <Style x:Key="BtnClose" TargetType="Button" BasedOn="{StaticResource BtnTitle}">
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="#C0392B"/><Setter Property="Foreground" Value="White"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- ══ ComboBox ══ -->
  <ControlTemplate x:Key="ComboToggle" TargetType="ToggleButton">
    <Border x:Name="b" Background="{StaticResource Field}" BorderBrush="{StaticResource Divider}" BorderThickness="1" CornerRadius="8"/>
    <ControlTemplate.Triggers>
      <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Neutral600}"/></Trigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>
  <Style TargetType="ComboBox">
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Height" Value="32"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBox">
          <Grid>
            <ToggleButton Focusable="False" Template="{StaticResource ComboToggle}"
                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
            <ContentPresenter x:Name="cp" Content="{TemplateBinding SelectionBoxItem}"
                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                              Margin="10,0,26,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
            <TextBox x:Name="PART_EditableTextBox" Margin="8,0,26,0" VerticalAlignment="Center"
                     Background="Transparent" BorderThickness="0" Foreground="{StaticResource Text}"
                     CaretBrush="{StaticResource Accent}" Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}">
              <TextBox.Template>
                <ControlTemplate TargetType="TextBox"><ScrollViewer x:Name="PART_ContentHost"/></ControlTemplate>
              </TextBox.Template>
            </TextBox>
            <Path Data="M3.5,6 L8,10.5 L12.5,6" Stroke="{StaticResource Neutral500}" StrokeThickness="1.6"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                  HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" IsHitTestVisible="False"/>
            <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom"
                   IsOpen="{TemplateBinding IsDropDownOpen}" Focusable="False" PopupAnimation="Slide">
              <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Neutral800}" BorderThickness="1"
                      CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}" Margin="0,4,0,0" Padding="4">
                <ScrollViewer MaxHeight="260"><ItemsPresenter/></ScrollViewer>
              </Border>
            </Popup>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsEditable" Value="True">
              <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
              <Setter TargetName="cp" Property="Visibility" Value="Hidden"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style TargetType="ComboBoxItem">
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Padding" Value="8,6"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBoxItem">
          <Border x:Name="b" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
            <ContentPresenter/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True"><Setter TargetName="b" Property="Background" Value="{StaticResource Accent900}"/></Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ CheckBox (opciones) ══ -->
  <Style TargetType="CheckBox">
    <Setter Property="Foreground" Value="{StaticResource Neutral400}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <StackPanel Orientation="Horizontal" Background="Transparent">
            <Border x:Name="box" Width="15" Height="15" CornerRadius="4" BorderThickness="1.5"
                    BorderBrush="{StaticResource Divider}" Background="Transparent" VerticalAlignment="Center">
              <Path x:Name="tick" Data="M2,5 L6,9 L12,2" Stroke="{StaticResource Accent200}" StrokeThickness="1.6"
                    StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Visibility="Collapsed"/>
            </Border>
            <ContentPresenter Margin="7,0,0,0" VerticalAlignment="Center"/>
          </StackPanel>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Accent}"/>
              <Setter TargetName="box" Property="Background" Value="{StaticResource Accent800}"/>
              <Setter TargetName="tick" Property="Visibility" Value="Visible"/>
              <Setter Property="Foreground" Value="{StaticResource Text}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Accent}"/></Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ ProgressBar ══ -->
  <Style TargetType="ProgressBar">
    <Setter Property="Height" Value="6"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ProgressBar">
          <Border Background="{StaticResource Field}" CornerRadius="3">
            <Grid>
              <Border x:Name="PART_Track"/>
              <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#796CBF" Offset="0"/><GradientStop Color="#B5ABFC" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
              </Border>
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ ListView / tabla ══ -->
  <Style x:Key="ColHeader" TargetType="GridViewColumnHeader">
    <Setter Property="Foreground" Value="#99E9E9ED"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="Padding" Value="8,6"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="GridViewColumnHeader">
          <Border Background="Transparent" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="RowStyle" TargetType="ListViewItem">
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListViewItem">
          <Border x:Name="strip" BorderBrush="Transparent" BorderThickness="2,0,0,0" Background="Transparent">
            <Border x:Name="fill" Background="Transparent">
              <GridViewRowPresenter VerticalAlignment="Center" Margin="0,7"/>
            </Border>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="fill" Property="Background" Value="{StaticResource RowHover}"/></Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="fill" Property="Background" Value="{StaticResource RowSelected}"/>
              <Setter TargetName="strip" Property="BorderBrush" Value="{StaticResource Accent}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="TableView" TargetType="ListView">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="ItemContainerStyle" Value="{StaticResource RowStyle}"/>
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
    <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
  </Style>

  <!-- ══ ScrollBar (oscuro, minimalista, vertical y horizontal) ══ -->
  <Style x:Key="ScrollThumbV" TargetType="Thumb">
    <Setter Property="Template"><Setter.Value>
      <ControlTemplate TargetType="Thumb"><Border Background="{StaticResource Neutral700}" CornerRadius="4" Margin="2,0"/></ControlTemplate>
    </Setter.Value></Setter>
  </Style>
  <Style x:Key="ScrollThumbH" TargetType="Thumb">
    <Setter Property="Template"><Setter.Value>
      <ControlTemplate TargetType="Thumb"><Border Background="{StaticResource Neutral700}" CornerRadius="4" Margin="0,2"/></ControlTemplate>
    </Setter.Value></Setter>
  </Style>
  <Style x:Key="ScrollNoop" TargetType="RepeatButton">
    <Setter Property="Opacity" Value="0"/>
    <Setter Property="Focusable" Value="False"/>
    <Setter Property="IsTabStop" Value="False"/>
    <Setter Property="Template">
      <Setter.Value><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></Setter.Value>
    </Setter>
  </Style>
  <ControlTemplate x:Key="VScroll" TargetType="ScrollBar">
    <Grid Background="Transparent">
      <Track x:Name="PART_Track" IsDirectionReversed="True">
        <Track.DecreaseRepeatButton><RepeatButton Style="{StaticResource ScrollNoop}" Command="ScrollBar.PageUpCommand"/></Track.DecreaseRepeatButton>
        <Track.Thumb><Thumb Style="{StaticResource ScrollThumbV}"/></Track.Thumb>
        <Track.IncreaseRepeatButton><RepeatButton Style="{StaticResource ScrollNoop}" Command="ScrollBar.PageDownCommand"/></Track.IncreaseRepeatButton>
      </Track>
    </Grid>
  </ControlTemplate>
  <ControlTemplate x:Key="HScroll" TargetType="ScrollBar">
    <Grid Background="Transparent">
      <Track x:Name="PART_Track">
        <Track.DecreaseRepeatButton><RepeatButton Style="{StaticResource ScrollNoop}" Command="ScrollBar.PageLeftCommand"/></Track.DecreaseRepeatButton>
        <Track.Thumb><Thumb Style="{StaticResource ScrollThumbH}"/></Track.Thumb>
        <Track.IncreaseRepeatButton><RepeatButton Style="{StaticResource ScrollNoop}" Command="ScrollBar.PageRightCommand"/></Track.IncreaseRepeatButton>
      </Track>
    </Grid>
  </ControlTemplate>
  <Style TargetType="ScrollBar">
    <Setter Property="Background" Value="Transparent"/>
    <Style.Triggers>
      <Trigger Property="Orientation" Value="Vertical">
        <Setter Property="Width" Value="10"/>
        <Setter Property="Template" Value="{StaticResource VScroll}"/>
      </Trigger>
      <Trigger Property="Orientation" Value="Horizontal">
        <Setter Property="Height" Value="10"/>
        <Setter Property="Template" Value="{StaticResource HScroll}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- ══ Slider tipo línea de tiempo (previsualización) ══ -->
  <Style x:Key="TimelineSlider" TargetType="Slider">
    <Setter Property="Height" Value="24"/>
    <Setter Property="IsMoveToPointEnabled" Value="True"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Slider">
          <Grid>
            <Border Height="18" CornerRadius="4" Background="{StaticResource Field}" BorderBrush="{StaticResource Neutral800}" BorderThickness="1" VerticalAlignment="Center"/>
            <Track x:Name="PART_Track">
              <Track.DecreaseRepeatButton>
                <RepeatButton Command="Slider.DecreaseLarge">
                  <RepeatButton.Template>
                    <ControlTemplate TargetType="RepeatButton"><Border Height="18" CornerRadius="4,0,0,4" Background="#33968AE0" VerticalAlignment="Center"/></ControlTemplate>
                  </RepeatButton.Template>
                </RepeatButton>
              </Track.DecreaseRepeatButton>
              <Track.IncreaseRepeatButton>
                <RepeatButton Command="Slider.IncreaseLarge">
                  <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template>
                </RepeatButton>
              </Track.IncreaseRepeatButton>
              <Track.Thumb>
                <Thumb>
                  <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                      <Grid Width="12" Background="Transparent">
                        <Rectangle Width="2" Fill="{StaticResource Accent}" HorizontalAlignment="Center"/>
                        <Border Width="11" Height="11" CornerRadius="6" Background="{StaticResource Accent}" VerticalAlignment="Top"/>
                        <Border Width="11" Height="11" CornerRadius="6" Background="{StaticResource Accent}" VerticalAlignment="Bottom"/>
                      </Grid>
                    </ControlTemplate>
                  </Thumb.Template>
                </Thumb>
              </Track.Thumb>
            </Track>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ Chip de idioma (píldora) ══ -->
  <Style x:Key="ChipStyle" TargetType="CheckBox">
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Margin" Value="0,0,6,0"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="11.5"/>
    <Setter Property="Foreground" Value="{StaticResource Neutral500}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <Border x:Name="b" CornerRadius="6" BorderThickness="1" BorderBrush="{StaticResource Divider}" Background="Transparent" Padding="10,3">
            <StackPanel Orientation="Horizontal">
              <TextBlock x:Name="tick" Text="✓" FontSize="10" Margin="0,0,4,0" Foreground="{StaticResource Accent200}" Visibility="Collapsed" VerticalAlignment="Center"/>
              <ContentPresenter VerticalAlignment="Center"/>
            </StackPanel>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="b" Property="Background" Value="{StaticResource Accent900}"/>
              <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent700}"/>
              <Setter TargetName="tick" Property="Visibility" Value="Visible"/>
              <Setter Property="Foreground" Value="{StaticResource Accent200}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ Barra de menú (oscura) ══ -->
  <Style TargetType="Menu">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Foreground" Value="{StaticResource Neutral400}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="12.5"/>
  </Style>

  <!-- Menú contextual: sin esto WPF pinta el panel claro del sistema -->
  <Style TargetType="ContextMenu">
    <Setter Property="Foreground" Value="{StaticResource Neutral300}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="HasDropShadow" Value="False"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ContextMenu">
          <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Divider}" BorderThickness="1"
                  CornerRadius="10" Padding="6" Margin="12" SnapsToDevicePixels="True" UseLayoutRounding="True">
            <Border.Effect><DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.45" Color="#000000"/></Border.Effect>
            <ItemsPresenter/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Separador de menú: WPF lo busca por SeparatorStyleKey (sin esto usa el clásico gris) -->
  <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="Separator">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Separator">
          <Border Height="1" Background="{StaticResource MenuSeparator}" Margin="10,5" SnapsToDevicePixels="True"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style TargetType="Separator" BasedOn="{StaticResource {x:Static MenuItem.SeparatorStyleKey}}"/>

  <Style TargetType="MenuItem">
    <Setter Property="Foreground" Value="{StaticResource Neutral300}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Padding" Value="10,7"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="MenuItem">
          <Border x:Name="wrap" Background="Transparent" CornerRadius="6" Margin="{TemplateBinding Margin}"
                  BorderBrush="Transparent" BorderThickness="3,0,0,0"
                  Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True" UseLayoutRounding="True">
            <Grid VerticalAlignment="Center">
              <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="colChk" Width="18"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="chk" Grid.Column="0" Text="✓" FontSize="11" VerticalAlignment="Center"
                         Foreground="{StaticResource Accent300}" Visibility="Collapsed"/>
              <ContentPresenter x:Name="hdr" Grid.Column="1" ContentSource="Header"
                                VerticalAlignment="Center" RecognizesAccessKey="True"/>
              <TextBlock x:Name="gesture" Grid.Column="2" Text="{TemplateBinding InputGestureText}"
                         FontSize="11" Margin="26,0,0,0" VerticalAlignment="Center"
                         Foreground="{StaticResource MenuGesture}"/>
              <Path x:Name="arrow" Grid.Column="3" Data="M0,0 L4,4 L0,8" Stroke="{StaticResource MenuGesture}"
                    StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                    Margin="18,0,2,0" VerticalAlignment="Center" Visibility="Collapsed"/>
              <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False" IsOpen="{TemplateBinding IsSubmenuOpen}"
                     Placement="Bottom" HorizontalOffset="-6" VerticalOffset="6" PopupAnimation="Fade">
                <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Divider}" BorderThickness="1"
                        CornerRadius="10" Padding="6" MinWidth="210" Margin="10,2,14,14"
                        SnapsToDevicePixels="True" UseLayoutRounding="True">
                  <Border.Effect><DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.45" Color="#000000"/></Border.Effect>
                  <ItemsPresenter/>
                </Border>
              </Popup>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <!-- barra superior: sin columna del ✓ (el texto queda centrado de verdad) -->
            <Trigger Property="Role" Value="TopLevelHeader">
              <Setter TargetName="colChk" Property="Width" Value="0"/>
              <Setter Property="Padding" Value="13,6"/>
              <Setter Property="Margin" Value="2,0"/>
            </Trigger>
            <Trigger Property="Role" Value="TopLevelItem">
              <Setter TargetName="colChk" Property="Width" Value="0"/>
              <Setter Property="Padding" Value="13,6"/>
              <Setter Property="Margin" Value="2,0"/>
            </Trigger>
            <Trigger Property="Role" Value="SubmenuItem">
              <Setter Property="Margin" Value="0,1"/>
            </Trigger>
            <Trigger Property="Role" Value="SubmenuHeader">
              <Setter Property="Margin" Value="0,1"/>
              <Setter TargetName="arrow" Property="Visibility" Value="Visible"/>
              <Setter TargetName="PART_Popup" Property="Placement" Value="Right"/>
              <Setter TargetName="PART_Popup" Property="HorizontalOffset" Value="2"/>
              <Setter TargetName="PART_Popup" Property="VerticalOffset" Value="-8"/>
            </Trigger>
            <Trigger Property="IsHighlighted" Value="True">
              <Setter TargetName="wrap" Property="Background" Value="{StaticResource MenuHighlight}"/>
              <Setter TargetName="wrap" Property="BorderBrush" Value="{StaticResource Accent300}"/>
              <Setter Property="Foreground" Value="{StaticResource Text}"/>
              <Setter TargetName="arrow" Property="Stroke" Value="{StaticResource Text}"/>
              <Setter TargetName="gesture" Property="Foreground" Value="{StaticResource Accent200}"/>
            </Trigger>
            <!-- la barra superior resalta en neutro, no en morado -->
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="Role" Value="TopLevelHeader"/>
                <Condition Property="IsHighlighted" Value="True"/>
              </MultiTrigger.Conditions>
              <Setter TargetName="wrap" Property="Background" Value="{StaticResource PressedPrimary}"/>
              <Setter Property="Foreground" Value="{StaticResource Text}"/>
            </MultiTrigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="Role" Value="TopLevelHeader"/>
                <Condition Property="IsSubmenuOpen" Value="True"/>
              </MultiTrigger.Conditions>
              <Setter TargetName="wrap" Property="Background" Value="{StaticResource PressedPrimary}"/>
              <Setter Property="Foreground" Value="{StaticResource Text}"/>
            </MultiTrigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="chk" Property="Visibility" Value="Visible"/>
            </Trigger>
            <!-- deshabilitado: color propio en vez de opacidad, que hundía el contraste a ~2:1 -->
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{StaticResource MenuDisabled}"/>
              <Setter TargetName="gesture" Property="Foreground" Value="{StaticResource MenuDisabled}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ TabControl / TabItem (oscuro, subrayado accent) ══ -->
  <Style TargetType="TabControl">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabControl">
          <DockPanel>
            <Border DockPanel.Dock="Top" BorderBrush="{StaticResource Divider}" BorderThickness="0,0,0,1">
              <TabPanel IsItemsHost="True" Panel.ZIndex="1" Margin="0" Background="Transparent"/>
            </Border>
            <ContentPresenter ContentSource="SelectedContent" Margin="0,14,0,0"/>
          </DockPanel>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="TabItem">
    <Setter Property="Foreground" Value="{StaticResource Neutral500}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabItem">
          <Border x:Name="b" BorderBrush="Transparent" BorderThickness="0,0,0,2" Padding="12,7" Margin="0,0,4,0">
            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Foreground" Value="{StaticResource Neutral300}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}"/>
              <Setter Property="Foreground" Value="{StaticResource Accent300}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ ToolTip (oscuro, legible, con sombra) ══ -->
  <Style TargetType="ToolTip">
    <Setter Property="Foreground" Value="{StaticResource Neutral300}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="11.5"/>
    <Setter Property="Placement" Value="Bottom"/>
    <Setter Property="VerticalOffset" Value="7"/>
    <Setter Property="HasDropShadow" Value="False"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToolTip">
          <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Divider}" BorderThickness="1"
                  CornerRadius="8" Padding="11,8" MaxWidth="330" Margin="6" SnapsToDevicePixels="True">
            <Border.Effect><DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.45" Color="#000000"/></Border.Effect>
            <ContentPresenter>
              <ContentPresenter.Resources>
                <!-- el texto plano del ToolTip se ajusta en varias líneas -->
                <DataTemplate DataType="{x:Type sys:String}">
                  <TextBlock Text="{Binding}" TextWrapping="Wrap" LineHeight="16.5"
                             LineStackingStrategy="BlockLineHeight"/>
                </DataTemplate>
              </ContentPresenter.Resources>
            </ContentPresenter>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ Elemento del desplegable de autocompletado ══ -->
  <Style x:Key="SuggestItem" TargetType="ListBoxItem">
    <Setter Property="Padding" Value="8,5"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListBoxItem">
          <Border x:Name="b" Background="Transparent" CornerRadius="5" Padding="{TemplateBinding Padding}">
            <ContentPresenter/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="b" Property="Background" Value="{StaticResource RowHover}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="b" Property="Background" Value="{StaticResource Accent900}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══ RadioButton (oscuro) ══ -->
  <Style TargetType="RadioButton">
    <Setter Property="Foreground" Value="{StaticResource Text}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Margin" Value="0,4"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <StackPanel Orientation="Horizontal" Background="Transparent">
            <Grid Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0">
              <Ellipse x:Name="ring" Stroke="{StaticResource Neutral600}" StrokeThickness="1.5"/>
              <Ellipse x:Name="dot" Width="8" Height="8" Fill="{StaticResource Accent}" Visibility="Collapsed"/>
            </Grid>
            <ContentPresenter VerticalAlignment="Center"/>
          </StackPanel>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="ring" Property="Stroke" Value="{StaticResource Accent400}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="ring" Property="Stroke" Value="{StaticResource Accent}"/>
              <Setter TargetName="dot" Property="Visibility" Value="Visible"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
