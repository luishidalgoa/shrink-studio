<Window x:Class="ShrinkVideo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShrinkStudio" Width="1180" Height="780" MinWidth="1000" MinHeight="660"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="CanResize"
        FontFamily="{StaticResource FontUI}" Foreground="{StaticResource Text}" Background="{StaticResource Bg}">
  <WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
  </WindowChrome.WindowChrome>
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="B2V"/>
  </Window.Resources>

  <Border x:Name="rootBorder" Background="{StaticResource Bg}">
    <Grid Margin="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/><!-- banner -->
        <RowDefinition Height="Auto"/><!-- titlebar -->
        <RowDefinition Height="Auto"/><!-- origen/destino -->
        <RowDefinition Height="Auto"/><!-- opciones -->
        <RowDefinition Height="*"/><!-- tabla+lateral -->
        <RowDefinition Height="Auto"/><!-- progreso -->
        <RowDefinition Height="Auto"/><!-- acciones -->
        <RowDefinition Height="Auto"/><!-- log -->
      </Grid.RowDefinitions>

      <!-- ══ Banner de actualización ══ -->
      <Border x:Name="updateBar" Grid.Row="0" Background="{StaticResource Accent900}" BorderBrush="{StaticResource Accent800}"
              BorderThickness="0,0,0,1" Padding="16,8" Visibility="Collapsed">
        <StackPanel Orientation="Horizontal">
          <Viewbox Width="15" Height="15" VerticalAlignment="Center">
            <Path Data="M8 1.5v3M8 11.5v3M1.5 8h3M11.5 8h3M3.5 3.5l2 2M10.5 10.5l2 2M12.5 3.5l-2 2M5.5 10.5l-2 2"
                  Stroke="{StaticResource Accent300}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
          </Viewbox>
          <TextBlock x:Name="lblUpdate" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="12.5"
                     Foreground="{StaticResource Accent200}" Text="Hay una versión nueva disponible."/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right" Margin="20,0,0,0">
            <Button x:Name="btnUpdateNow" Style="{StaticResource BtnPrimary}" Content="Actualizar ahora" FontSize="12" Padding="12,4"/>
            <Button x:Name="btnUpdateLater" Style="{StaticResource BtnGhost}" Content="Después" FontSize="12" Foreground="{StaticResource Accent300}" Margin="6,0,0,0"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- ══ Barra de título ══ -->
      <Grid Grid.Row="1" Height="40">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
          <Border Width="26" Height="26" CornerRadius="8" VerticalAlignment="Center">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#968AE0" Offset="0"/><GradientStop Color="#5D5294" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
            <Viewbox Width="14" Height="14">
              <Canvas Width="16" Height="16">
                <Path Data="M6.2 5l4.2 3-4.2 3z" Fill="#F5F4FF"/>
                <Path Data="M2 5.5L3.5 8 2 10.5M14 5.5L12.5 8 14 10.5" Stroke="#F5F4FF" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
              </Canvas>
            </Viewbox>
          </Border>
          <TextBlock Text="ShrinkStudio" FontSize="15" FontWeight="Medium" Foreground="{StaticResource Text}" VerticalAlignment="Center" Margin="10,0,0,0"/>
          <TextBlock x:Name="lblVersion" Text="v0.3.0" FontSize="11" Foreground="{StaticResource Neutral600}" VerticalAlignment="Center" Margin="8,2,0,0"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" WindowChrome.IsHitTestVisibleInChrome="True">
          <Button x:Name="btnMin" Style="{StaticResource BtnTitle}">
            <Path Data="M2,8 H12" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.2" Width="14" Height="14" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Button>
          <Button x:Name="btnMax" Style="{StaticResource BtnTitle}">
            <Border Width="9" Height="9" BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" BorderThickness="1.2" CornerRadius="1.5"/>
          </Button>
          <Button x:Name="btnClose" Style="{StaticResource BtnClose}">
            <Path Data="M2,2 L11,11 M11,2 L2,11" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.2" Width="13" Height="13" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Button>
        </StackPanel>
      </Grid>

      <!-- ══ Origen / Destino ══ -->
      <Grid Grid.Row="2" Margin="16,4,16,10">
        <Grid.ColumnDefinitions><ColumnDefinition Width="1.5*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
          <TextBlock Text="Origen" FontSize="11" Foreground="{StaticResource Neutral500}" Margin="0,0,0,4"/>
          <StackPanel Orientation="Horizontal">
            <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Divider}" BorderThickness="1" CornerRadius="8"
                    Height="34" Width="330">
              <Grid Margin="10,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Viewbox Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center">
                  <Path Data="M1.5 3.5h4l1.5 2h7.5v7h-13z" Stroke="{StaticResource Neutral500}" StrokeThickness="1.4" StrokeLineJoin="Round"/>
                </Viewbox>
                <TextBox x:Name="txtSrc" Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="0" VerticalContentAlignment="Center"/>
              </Grid>
            </Border>
            <Button x:Name="btnSrc" Style="{StaticResource BtnSecondary}" Width="34" Height="34" Padding="0" Margin="6,0,0,0" ToolTip="Elegir carpeta">
              <Viewbox Width="15" Height="15"><Path Data="M1.5 3.5h4l1.5 2h7.5l-2 7h-11z M1.5 3.5v9h11" Stroke="{StaticResource Text}" StrokeThickness="1.4" StrokeLineJoin="Round"/></Viewbox>
            </Button>
            <Button x:Name="btnSrcFile" Style="{StaticResource BtnSecondary}" Height="34" Margin="6,0,0,0" ToolTip="Añadir uno o varios archivos sueltos">
              <StackPanel Orientation="Horizontal">
                <Viewbox Width="14" Height="14" Margin="0,0,6,0"><Path Data="M4 1.5h5l3 3v10h-8z M9 1.5v3h3 M6.5 9.5h3 M8 8v3" Stroke="{StaticResource Text}" StrokeThickness="1.4" StrokeLineJoin="Round" StrokeStartLineCap="Round"/></Viewbox>
                <TextBlock Text="Añadir archivos" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </StackPanel>
        <StackPanel Grid.Column="2">
          <TextBlock VerticalAlignment="Center" Margin="0,0,0,4"><Run Text="Destino " FontSize="11" Foreground="#9397AB"/><Run Text="(opcional)" FontSize="11" Foreground="#595D6C"/></TextBlock>
          <StackPanel Orientation="Horizontal">
            <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Divider}" BorderThickness="1" CornerRadius="8" Height="34" Width="300">
              <TextBox x:Name="txtOut" Background="Transparent" BorderThickness="0" Margin="10,0" VerticalContentAlignment="Center"
                       ToolTip="Vacío = subcarpeta 'comprimido' junto al origen"/>
            </Border>
            <Button x:Name="btnOut" Style="{StaticResource BtnSecondary}" Width="34" Height="34" Padding="0" Margin="6,0,0,0" ToolTip="Elegir destino">
              <Viewbox Width="15" Height="15"><Path Data="M1.5 3.5h4l1.5 2h7.5l-2 7h-11z M1.5 3.5v9h11" Stroke="{StaticResource Text}" StrokeThickness="1.4" StrokeLineJoin="Round"/></Viewbox>
            </Button>
          </StackPanel>
        </StackPanel>
      </Grid>

      <!-- ══ Panel de opciones ══ -->
      <Border Grid.Row="3" Margin="16,0,16,0" Background="{StaticResource Surface}" CornerRadius="8" Padding="12,10">
        <StackPanel>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="1.2*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
              <TextBlock Text="Idioma principal" FontSize="11" Foreground="{StaticResource Neutral500}" Margin="0,0,0,4"/>
              <ComboBox x:Name="cboLang" IsEditable="True" Text="spa">
                <ComboBoxItem Content="spa"/><ComboBoxItem Content="eng"/><ComboBoxItem Content="por"/>
                <ComboBoxItem Content="fra"/><ComboBoxItem Content="ita"/><ComboBoxItem Content="deu"/><ComboBoxItem Content="jpn"/>
              </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="0,0,10,0">
              <TextBlock Text="Formato" FontSize="11" Foreground="{StaticResource Neutral500}" Margin="0,0,0,4"/>
              <ComboBox x:Name="cboFmt" SelectedIndex="0"><ComboBoxItem Content="MKV"/><ComboBoxItem Content="MP4"/></ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="0,0,10,0">
              <TextBlock Text="Códec" FontSize="11" Foreground="{StaticResource Neutral500}" Margin="0,0,0,4"/>
              <ComboBox x:Name="cboCodec" SelectedIndex="0"><ComboBoxItem Content="H.265"/><ComboBoxItem Content="H.264"/><ComboBoxItem Content="AV1"/></ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="3" Margin="0,0,10,0">
              <TextBlock Text="Calidad" FontSize="11" Foreground="{StaticResource Neutral500}" Margin="0,0,0,4"/>
              <ComboBox x:Name="cboQ" SelectedIndex="0">
                <ComboBoxItem Content="Automática"/><ComboBoxItem Content="22 · muy alta"/><ComboBoxItem Content="24 · alta"/>
                <ComboBoxItem Content="27 · equilibrada"/><ComboBoxItem Content="30 · muy comprimida"/>
              </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="4" Margin="0,0,10,0">
              <TextBlock Text="Resolución máx." FontSize="11" Foreground="{StaticResource Neutral500}" Margin="0,0,0,4"/>
              <ComboBox x:Name="cboRes" SelectedIndex="0">
                <ComboBoxItem Content="Sin cambio"/><ComboBoxItem Content="1080p"/><ComboBoxItem Content="720p"/><ComboBoxItem Content="480p"/>
              </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="5" Margin="0,0,10,0">
              <TextBlock Text="Audio" FontSize="11" Foreground="{StaticResource Neutral500}" Margin="0,0,0,4"/>
              <ComboBox x:Name="cboAud" SelectedIndex="0">
                <ComboBoxItem Content="Máxima (copiar original)"/><ComboBoxItem Content="AAC 192 kbps"/>
                <ComboBoxItem Content="AAC 160 kbps"/><ComboBoxItem Content="AAC 128 kbps"/><ComboBoxItem Content="AAC 96 kbps"/>
              </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="6" Margin="4,0,0,0" Orientation="Vertical">
              <StackPanel.Resources><Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}"><Setter Property="Margin" Value="8,1"/></Style></StackPanel.Resources>
              <Border BorderBrush="{StaticResource Divider}" BorderThickness="1,0,0,0" Padding="10,0,0,0">
                <StackPanel>
                  <CheckBox x:Name="chkRec" Content="Subcarpetas" IsChecked="True"/>
                  <CheckBox x:Name="chkForce" Content="Reprocesar hechos"/>
                  <CheckBox x:Name="chkDry" Content="Solo simular"/>
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
          <Border BorderBrush="{StaticResource Divider}" BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="0,8,0,0">
            <StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Audio detectado" Width="106" FontSize="11" Foreground="{StaticResource Neutral500}" VerticalAlignment="Center"/>
                <WrapPanel x:Name="pnlALang" VerticalAlignment="Center"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="Subtítulos" Width="106" FontSize="11" Foreground="{StaticResource Neutral500}" VerticalAlignment="Center"/>
                <WrapPanel x:Name="pnlSLang" VerticalAlignment="Center"/>
                <TextBlock x:Name="lblLangHint" Text="(pulsa Analizar para detectarlos)" FontSize="11" Foreground="{StaticResource Neutral700}" VerticalAlignment="Center" Margin="4,0,0,0"/>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <!-- ══ Tabla + panel lateral ══ -->
      <Grid Grid.Row="4" Margin="16,10,16,0">
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="262"/></Grid.ColumnDefinitions>
        <Border Background="{StaticResource Surface}" CornerRadius="8" Padding="0,4">
          <ListView x:Name="lst" Style="{StaticResource TableView}" SelectionMode="Extended" SelectionChanged="OnSelectionChanged">
            <ListView.View>
              <GridView ColumnHeaderContainerStyle="{StaticResource ColHeader}">
                <GridViewColumn Width="40">
                  <GridViewColumn.CellTemplate><DataTemplate>
                    <CheckBox IsChecked="{Binding Sel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="12,0,0,0"/>
                  </DataTemplate></GridViewColumn.CellTemplate>
                </GridViewColumn>
                <GridViewColumn Header="VÍDEO" Width="300" DisplayMemberBinding="{Binding Name}"/>
                <GridViewColumn Header="CARPETA" Width="130" DisplayMemberBinding="{Binding Dir}"/>
                <GridViewColumn Header="TAMAÑO" Width="80" DisplayMemberBinding="{Binding SizeMB}"/>
                <GridViewColumn Header="DURACIÓN" Width="76" DisplayMemberBinding="{Binding Dur}"/>
                <GridViewColumn Header="CÓDEC" Width="64" DisplayMemberBinding="{Binding Codec}"/>
                <GridViewColumn Header="AUDIO" Width="88" DisplayMemberBinding="{Binding Audio}"/>
                <GridViewColumn Header="SUBS" Width="64" DisplayMemberBinding="{Binding Subs}"/>
                <GridViewColumn Header="ESTADO" Width="104" DisplayMemberBinding="{Binding Estado}"/>
              </GridView>
            </ListView.View>
          </ListView>
        </Border>

        <StackPanel Grid.Column="1" Margin="10,0,0,0">
          <Border Background="{StaticResource Surface}" CornerRadius="8" Padding="10" Margin="0,0,0,8">
            <StackPanel>
              <!-- pestañas del panel lateral -->
              <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Border x:Name="tabDetalle" BorderThickness="0,0,0,2" BorderBrush="{StaticResource Accent}" Padding="2,0,2,5" Margin="0,0,14,0" Cursor="Hand">
                  <TextBlock Text="Detalle" FontSize="12.5" Foreground="{StaticResource Accent300}"/>
                </Border>
                <Border x:Name="tabEstim" BorderThickness="0,0,0,2" BorderBrush="Transparent" Padding="2,0,2,5" Cursor="Hand">
                  <TextBlock Text="Estimación" FontSize="12.5" Foreground="{StaticResource Neutral400}"/>
                </Border>
              </StackPanel>

              <!-- Detalle -->
              <StackPanel x:Name="panelDetalle">
                <Border CornerRadius="4" Height="130" ClipToBounds="True">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#292B31" Offset="0"/><GradientStop Color="#161826" Offset="0.7"/></LinearGradientBrush>
                  </Border.Background>
                  <Image x:Name="imgPrev" Stretch="Uniform"/>
                </Border>
                <TextBlock x:Name="lblPrevName" Margin="0,10,0,2" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" FontWeight="Medium" FontSize="12.5"/>
                <TextBlock x:Name="lblPrevInfo" Foreground="{StaticResource Neutral500}" TextWrapping="Wrap" FontSize="11.5"/>
              </StackPanel>

              <!-- Estimación -->
              <StackPanel x:Name="panelEstim" Visibility="Collapsed">
                <Border Background="{StaticResource Accent900}" CornerRadius="6" Padding="10,8" Margin="0,0,0,10">
                  <StackPanel>
                    <TextBlock Text="TAMAÑO ESTIMADO" FontSize="10" Foreground="{StaticResource Accent400}"/>
                    <TextBlock x:Name="lblEstSize" Text="—" FontSize="18" FontWeight="Medium" Foreground="{StaticResource Accent200}" Margin="0,2,0,0"/>
                    <TextBlock x:Name="lblEstSaving" Text="Selecciona un vídeo analizado" FontSize="11.5" Foreground="{StaticResource Accent300}"/>
                  </StackPanel>
                </Border>
                <TextBlock Text="VÍDEO" FontSize="10" Foreground="{StaticResource Neutral500}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="54"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                  <TextBlock Text="Calidad" FontSize="11" Foreground="{StaticResource Neutral400}" VerticalAlignment="Center"/>
                  <StackPanel x:Name="barVQ" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"/>
                </Grid>
                <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="54"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                  <TextBlock Text="Ahorro" FontSize="11" Foreground="{StaticResource Neutral400}" VerticalAlignment="Center"/>
                  <StackPanel x:Name="barVS" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"/>
                </Grid>
                <TextBlock Text="AUDIO" FontSize="10" Foreground="{StaticResource Neutral500}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="54"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                  <TextBlock Text="Calidad" FontSize="11" Foreground="{StaticResource Neutral400}" VerticalAlignment="Center"/>
                  <StackPanel x:Name="barAQ" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"/>
                </Grid>
                <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="54"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                  <TextBlock Text="Ahorro" FontSize="11" Foreground="{StaticResource Neutral400}" VerticalAlignment="Center"/>
                  <StackPanel x:Name="barAS" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"/>
                </Grid>
                <TextBlock x:Name="lblEstDetail" FontSize="10.5" Foreground="{StaticResource Neutral600}" TextWrapping="Wrap"/>
              </StackPanel>
            </StackPanel>
          </Border>
          <Border Background="{StaticResource Surface}" CornerRadius="8" Padding="8">
            <StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <Button x:Name="btnMarkAll" Style="{StaticResource BtnSecondary}" Content="Marcar todos" FontSize="12" Padding="5,6" Width="112" Margin="0,0,6,0"/>
                <Button x:Name="btnMarkNone" Style="{StaticResource BtnSecondary}" Content="Desmarcar" FontSize="12" Padding="5,6" Width="112"/>
              </StackPanel>
              <Button x:Name="btnDelSel" Style="{StaticResource BtnSecondary}" HorizontalContentAlignment="Left" FontSize="12" Padding="10,6" Margin="0,0,0,6" ToolTip="Enviar los marcados a la Papelera">
                <StackPanel Orientation="Horizontal">
                  <Viewbox Width="13" Height="13" Margin="0,0,7,0"><Path Data="M2.5 4h11 M5.5 4V2.5h5V4 M4 4l.8 9.5h6.4L12 4 M6.7 6.5v4.5 M9.3 6.5v4.5" Stroke="{StaticResource Neutral400}" StrokeThickness="1.4" StrokeLineJoin="Round" StrokeStartLineCap="Round"/></Viewbox>
                  <TextBlock Text="Eliminar marcados" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button x:Name="btnDelDir" Style="{StaticResource BtnSecondary}" HorizontalContentAlignment="Left" FontSize="12" Padding="10,6" ToolTip="Enviar una carpeta entera a la Papelera">
                <StackPanel Orientation="Horizontal">
                  <Viewbox Width="13" Height="13" Margin="0,0,7,0"><Path Data="M2.5 4h11 M5.5 4V2.5h5V4 M4 4l.8 9.5h6.4L12 4" Stroke="{StaticResource Neutral400}" StrokeThickness="1.4" StrokeLineJoin="Round" StrokeStartLineCap="Round"/></Viewbox>
                  <TextBlock Text="Eliminar carpeta" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>

      <!-- ══ Progreso ══ -->
      <Grid x:Name="progRow" Grid.Row="5" Margin="16,8,16,0" Visibility="Collapsed">
        <ProgressBar x:Name="bar" Minimum="0" Maximum="1" Value="0"/>
      </Grid>

      <!-- ══ Acciones ══ -->
      <Grid Grid.Row="6" Margin="16,10,16,8">
        <StackPanel Orientation="Horizontal">
          <Button x:Name="btnScan" Style="{StaticResource BtnPrimary}" Margin="0,0,8,0">
            <StackPanel Orientation="Horizontal">
              <Viewbox Width="14" Height="14" Margin="0,0,6,0"><Canvas Width="16" Height="16"><Ellipse Width="9" Height="9" Canvas.Left="2.5" Canvas.Top="2.5" Stroke="#968AE0" StrokeThickness="1.5"/><Path Data="M10.5 10.5L14 14" Stroke="#968AE0" StrokeThickness="1.5" StrokeStartLineCap="Round"/></Canvas></Viewbox>
              <TextBlock Text="Analizar" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button x:Name="btnRun" Style="{StaticResource BtnPrimary}" Margin="0,0,8,0">
            <StackPanel Orientation="Horizontal">
              <Viewbox Width="14" Height="14" Margin="0,0,6,0"><Path Data="M2 2l4 4M6 3.5V6H3.5M14 14l-4-4M10 12.5V10h2.5" Stroke="#968AE0" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeLineJoin="Round"/></Viewbox>
              <TextBlock Text="Comprimir marcados" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button x:Name="btnPause" Style="{StaticResource BtnSecondary}" Content="Pausar" IsEnabled="False" Margin="0,0,8,0"/>
          <Button x:Name="btnCancel" Style="{StaticResource BtnSecondary}" Content="Detener" IsEnabled="False" Margin="0,0,8,0"/>
          <Button x:Name="btnOpen" Style="{StaticResource BtnGhost}">
            <StackPanel Orientation="Horizontal">
              <Viewbox Width="14" Height="14" Margin="0,0,6,0"><Path Data="M1.5 3.5h4l1.5 2h7.5l-2 7h-11z M1.5 3.5v9h11" Stroke="#968AE0" StrokeThickness="1.4" StrokeLineJoin="Round"/></Viewbox>
              <TextBlock Text="Abrir destino" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
          <TextBlock x:Name="lblProg" Text="Listo." VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource Neutral500}" Margin="0,0,12,0"/>
          <Button x:Name="btnCheckUpdate" Style="{StaticResource BtnGhostMuted}" Content="Buscar actualizaciones"/>
        </StackPanel>
      </Grid>

      <!-- ══ Registro ══ -->
      <StackPanel Grid.Row="7" Margin="16,0,16,10">
        <Rectangle Height="1" Fill="{StaticResource FadedRule}" Margin="0,0,0,6"/>
        <ToggleButton x:Name="tglLog" Cursor="Hand" HorizontalAlignment="Left" Background="Transparent" BorderThickness="0">
          <ToggleButton.Template>
            <ControlTemplate TargetType="ToggleButton">
              <StackPanel Orientation="Horizontal" Background="Transparent">
                <Path x:Name="car" Data="M5 3l6 5-6 5" Stroke="{StaticResource Neutral500}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeLineJoin="Round" Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5"/>
                <TextBlock Text="Registro" Margin="7,0,0,0" FontSize="11.5" Foreground="{StaticResource Neutral500}" VerticalAlignment="Center"/>
              </StackPanel>
              <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                  <Setter TargetName="car" Property="RenderTransform"><Setter.Value><RotateTransform Angle="90"/></Setter.Value></Setter>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </ToggleButton.Template>
        </ToggleButton>
        <Border Margin="0,6,0,0" Background="{StaticResource Field}" CornerRadius="4"
                Visibility="{Binding IsChecked, ElementName=tglLog, Converter={StaticResource B2V}}">
          <TextBox x:Name="txtLog" Height="120" IsReadOnly="True" Background="Transparent" BorderThickness="0"
                   Foreground="{StaticResource Neutral400}" FontFamily="{StaticResource FontMono}" FontSize="11"
                   Padding="10,8" VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap"/>
        </Border>
      </StackPanel>
    </Grid>
  </Border>
</Window>
