<Window x:Class="ShrinkVideo.DialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShrinkStudio" SizeToContent="Height" Width="460" MinWidth="360"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="{StaticResource FontUI}" Foreground="{StaticResource Text}"
        Background="{StaticResource Bg}">
  <WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="38" ResizeBorderThickness="0" CornerRadius="0" GlassFrameThickness="0"
                  UseAeroCaptionButtons="False"/>
  </WindowChrome.WindowChrome>

  <Border Background="{StaticResource Bg}" BorderBrush="{StaticResource Divider}" BorderThickness="1"
          CornerRadius="8">
    <Grid Margin="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/><!-- titulo -->
        <RowDefinition Height="Auto"/><!-- mensaje -->
        <RowDefinition Height="Auto"/><!-- acciones -->
      </Grid.RowDefinitions>

      <TextBlock x:Name="lblTitulo" Grid.Row="0" Margin="20,18,20,0" FontSize="15" FontWeight="Medium"
                 Foreground="{StaticResource Text}" TextWrapping="Wrap"/>

      <!-- El mensaje es seleccionable a propósito: muchos avisos traen una ruta o el texto
           de un error, y copiarlo es justo lo que hace falta para poder buscarlo. -->
      <TextBox x:Name="txtMensaje" Grid.Row="1" Margin="20,10,20,0" IsReadOnly="True"
               Background="Transparent" BorderThickness="0" Padding="0"
               Foreground="{StaticResource Neutral300}" FontSize="13" TextWrapping="Wrap"
               MaxHeight="320" VerticalScrollBarVisibility="Auto"/>

      <Grid Grid.Row="2" Margin="20,20,20,18">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button x:Name="btnNo" Style="{StaticResource BtnSecondary}" Margin="0,0,8,0"
                  Visibility="Collapsed" IsCancel="True"/>
          <Button x:Name="btnSi" Style="{StaticResource BtnPrimary}" IsDefault="True" MinWidth="96"/>
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
