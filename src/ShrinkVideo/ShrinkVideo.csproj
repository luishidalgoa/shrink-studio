<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <AssemblyName>ShrinkVideo</AssemblyName>
    <RootNamespace>ShrinkVideo</RootNamespace>
    <ApplicationIcon>Assets\app.ico</ApplicationIcon>
    <ApplicationManifest>app.manifest</ApplicationManifest>

    <!-- Versión: única fuente para el ejecutable, el instalador y el auto-update -->
    <Version>0.7.0</Version>
    <Product>ShrinkStudio</Product>
    <!-- FileDescription del exe: es el nombre que muestra el submenú «Abrir con» -->
    <AssemblyTitle>ShrinkStudio</AssemblyTitle>
    <Company>luishidalgoa</Company>
    <Authors>luishidalgoa</Authors>
    <Description>ShrinkStudio — compresor de vídeo por lotes: reduce a HEVC/H.264/AV1 en MKV/MP4/WebM con aceleración por hardware, conservando los idiomas de audio elegidos y sin tocar los originales.</Description>
    <Copyright>© luishidalgoa</Copyright>

    <!-- Repo de GitHub del que la app descarga sus actualizaciones -->
    <UpdateRepo>luishidalgoa/shrink-studio</UpdateRepo>
  </PropertyGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
      <_Parameter1>UpdateRepo</_Parameter1>
      <_Parameter2>$(UpdateRepo)</_Parameter2>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\app.ico" />
  </ItemGroup>

</Project>
