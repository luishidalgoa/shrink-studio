<Window x:Class="ShrinkVideo.CatalogoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Explorar el catálogo" Width="920" Height="620" MinWidth="560" MinHeight="380"
        WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        FontFamily="{StaticResource FontUI}" Foreground="{StaticResource Text}" Background="{StaticResource Bg}">
  <WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="38" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0"
                  UseAeroCaptionButtons="False"/>
  </WindowChrome.WindowChrome>

  <Border Background="{StaticResource Bg}" BorderBrush="{StaticResource Divider}" BorderThickness="1" CornerRadius="8">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/><!-- título -->
        <RowDefinition Height="Auto"/><!-- buscador -->
        <RowDefinition Height="*"/>   <!-- lista -->
        <RowDefinition Height="Auto"/><!-- pie -->
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" Height="38">
        <TextBlock x:Name="lblTitulo" Text="Explorar el catálogo" FontSize="13.5" FontWeight="Medium"
                   VerticalAlignment="Center" Margin="16,0,0,0"/>
        <Button x:Name="btnCerrar" Style="{StaticResource BtnClose}" HorizontalAlignment="Right"
                WindowChrome.IsHitTestVisibleInChrome="True">
          <Path Data="M2,2 L11,11 M11,2 L2,11" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                StrokeThickness="1.2" Width="13" Height="13" Stretch="None"
                HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Button>
      </Grid>

      <Grid Grid.Row="1" Margin="16,0,16,10">
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <TextBox x:Name="txtBuscar"
                 ToolTip="Escribe un número («175») o parte de un título («planeta espejo»). Busca igual que el identificador: sin tildes y con «2.ª» = «segunda»."/>
        <TextBlock x:Name="lblCuenta" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                   FontSize="11.5" Foreground="{StaticResource Neutral500}"/>
      </Grid>

      <Grid Grid.Row="2" Margin="16,0,16,10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition x:Name="colJson" Width="0"/>
        </Grid.ColumnDefinitions>

      <!-- ListBox y no ItemsControl: con cientos de episodios hace falta virtualización -->
      <ListBox x:Name="lista" Grid.Column="0" Background="Transparent" BorderThickness="0"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
               VirtualizingPanel.VirtualizationMode="Recycling">
        <ListBox.ItemContainerStyle>
          <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
              <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                  <Border x:Name="b" Background="Transparent" CornerRadius="6" Padding="10,7">
                    <ContentPresenter/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="b" Property="Background" Value="{StaticResource RowHover}"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                      <Setter TargetName="b" Property="Background" Value="{StaticResource RowSelected}"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
          </Style>
        </ListBox.ItemContainerStyle>
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="62"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Text="{Binding Codigo}" FontFamily="{StaticResource FontMono}" FontSize="12"
                         Foreground="{StaticResource Accent}" VerticalAlignment="Top" Margin="0,1,0,0"/>
              <StackPanel Grid.Column="1">
                <TextBlock Text="{Binding Titulos}" FontSize="12.5" TextWrapping="Wrap"
                           Foreground="{StaticResource Text}"/>
                <TextBlock Text="{Binding Detalle}" FontSize="11" Margin="0,1,0,0"
                           Foreground="{StaticResource Neutral500}"/>
              </StackPanel>
              <Border Grid.Column="2" Background="{StaticResource Accent900}" CornerRadius="6" Padding="7,2"
                      VerticalAlignment="Top" Visibility="{Binding EsEspecial}">
                <TextBlock Text="especial" FontSize="10.5" Foreground="{StaticResource Accent200}"/>
              </Border>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

        <!-- El JSON del episodio elegido, tal y como está en el catálogo: la referencia
             final cuando la vista bonita no basta. Emerge al elegir una fila. -->
        <Border x:Name="bordeJson" Grid.Column="1" Margin="10,0,0,0" Background="{StaticResource Field}"
                BorderBrush="{StaticResource Divider}" BorderThickness="1" CornerRadius="8"
                Visibility="Collapsed">
          <Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Grid Margin="12,9,10,4">
              <TextBlock x:Name="lblJsonTitulo" FontSize="12" FontWeight="Medium"
                         Foreground="{StaticResource Accent300}" VerticalAlignment="Center"/>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnCopiarJson" Style="{StaticResource BtnGhostMuted}" Content="Copiar"
                        FontSize="11" Padding="7,2"/>
                <Button x:Name="btnCerrarJson" Style="{StaticResource BtnGhostMuted}" Content="✕"
                        FontSize="10" Padding="6,2" Margin="4,0,0,0"
                        ToolTip="Cerrar el panel del JSON"/>
              </StackPanel>
            </Grid>
            <!-- RichTextBox y no TextBox: es el que sabe pintar cada trozo de un color.
                 Sigue siendo de solo lectura y con selección para copiar a mano. -->
            <RichTextBox x:Name="rtbJson" Grid.Row="1" IsReadOnly="True" Background="Transparent"
                         BorderThickness="0" FontFamily="{StaticResource FontMono}" FontSize="11.5"
                         Padding="6,0,6,8" VerticalScrollBarVisibility="Auto"
                         IsUndoEnabled="False"/>
          </Grid>
        </Border>
      </Grid>

      <TextBlock x:Name="lblPie" Grid.Row="3" Margin="16,0,16,12" FontSize="11.5" TextWrapping="Wrap"
                 Foreground="{StaticResource Neutral500}"
                 Text="Solo lectura: es la referencia contra la que se identifica. Para cambiar un fichero de episodio, usa su fila en la tabla."/>

      <!-- Pregunta de historia (solo en modo elegir, con episodios multi-historia) -->
      <Border x:Name="overlayHistoria" Grid.RowSpan="4" Background="#CC161826" Visibility="Collapsed">
        <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Divider}" BorderThickness="1"
                CornerRadius="8" MaxWidth="500" VerticalAlignment="Center" HorizontalAlignment="Center"
                Padding="18,16" Margin="24">
          <StackPanel>
            <TextBlock x:Name="lblHistoriaTitulo" FontSize="13" FontWeight="Medium" TextWrapping="Wrap"/>
            <TextBlock Margin="0,6,0,12" FontSize="12" Foreground="{StaticResource Neutral500}"
                       TextWrapping="Wrap" LineHeight="18"
                       Text="Si el fichero trae el episodio entero, elige «Completo». Si es solo una de sus historias, di cuál: la letra irá pegada al número (E413b) y el título será el de esa historia."/>
            <StackPanel x:Name="panelHistorias"/>
          </StackPanel>
        </Border>
      </Border>
    </Grid>
  </Border>
</Window>
