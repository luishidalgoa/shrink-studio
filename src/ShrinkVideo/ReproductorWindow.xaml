<Window x:Class="ShrinkVideo.ReproductorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reproductor" Width="1120" Height="680" MinWidth="560" MinHeight="360"
        WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        FontFamily="{StaticResource FontUI}" Foreground="{StaticResource Text}" Background="#08090F">
  <WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0"
                  UseAeroCaptionButtons="False"/>
  </WindowChrome.WindowChrome>

  <Window.Resources>
    <!-- El acento recorre la parte ya vista: morado donde empezó, cian en el punto de
         reproducción. Da sensación de avance sin necesidad de animar nada. -->
    <LinearGradientBrush x:Key="Recorrido" StartPoint="0,0" EndPoint="1,0">
      <GradientStop Color="#968AE0" Offset="0"/>
      <GradientStop Color="#63D2E8" Offset="1"/>
    </LinearGradientBrush>

    <!-- ══ Barra de posición ══
         Riel de 3 px y punto blanco de 11 que crece al pasar por encima. El área de
         click son 18 px: el riel fino es para mirarlo, no para acertarle con el ratón. -->
    <Style x:Key="BarraVideo" TargetType="Slider">
      <Setter Property="IsMoveToPointEnabled" Value="True"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Height" Value="18"/>
      <Setter Property="Focusable" Value="False"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Slider">
            <Grid Background="Transparent">
              <Border Height="3" CornerRadius="2" Background="#2EFFFFFF" VerticalAlignment="Center"/>
              <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                    <RepeatButton.Template>
                      <ControlTemplate TargetType="RepeatButton">
                        <Border Height="3" CornerRadius="2" VerticalAlignment="Center"
                                Background="{StaticResource Recorrido}"/>
                      </ControlTemplate>
                    </RepeatButton.Template>
                  </RepeatButton>
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                    <RepeatButton.Template>
                      <ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate>
                    </RepeatButton.Template>
                  </RepeatButton>
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                  <Thumb Focusable="False">
                    <Thumb.Template>
                      <ControlTemplate TargetType="Thumb">
                        <Grid Width="18" Height="18" Background="Transparent">
                          <Ellipse x:Name="bola" Width="11" Height="11" Fill="White"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bola" Property="Width" Value="15"/>
                            <Setter TargetName="bola" Property="Height" Value="15"/>
                          </Trigger>
                          <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="bola" Property="Width" Value="15"/>
                            <Setter TargetName="bola" Property="Height" Value="15"/>
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ══ Volumen ══ mismo lenguaje, en pequeño -->
    <Style x:Key="BarraVolumen" TargetType="Slider" BasedOn="{StaticResource BarraVideo}">
      <Setter Property="Height" Value="16"/>
      <Setter Property="Width" Value="74"/>
    </Style>

    <!-- ══ Botón de icono ══ el círculo de fondo solo aparece al pasar por encima -->
    <Style x:Key="BtnIcono" TargetType="Button">
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Focusable" Value="False"/>
      <Setter Property="Foreground" Value="#E4E6F2"/>
      <Setter Property="Width" Value="34"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Grid Background="Transparent">
              <Ellipse x:Name="fondo" Fill="#1FFFFFFF" Opacity="0"/>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="fondo" Property="Opacity" Value="1"/>
                <Setter Property="Foreground" Value="White"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="fondo" Property="Fill" Value="#33FFFFFF"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ══ Botón grande de reproducir ══
         El aro degradado es el único elemento de color fuerte de la ventana: marca
         dónde está la acción principal sin necesidad de más adornos. -->
    <Style x:Key="BtnPlay" TargetType="Button">
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Focusable" Value="False"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Grid Width="48" Height="48" Background="Transparent">
              <Ellipse x:Name="aro" StrokeThickness="2.2" Stroke="{StaticResource Recorrido}"/>
              <Ellipse x:Name="relleno" Margin="2.5" Fill="#1AFFFFFF" Opacity="0"/>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="relleno" Property="Opacity" Value="1"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="relleno" Property="Fill" Value="#2EFFFFFF"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid x:Name="raiz" Background="#08090F">
    <MediaElement x:Name="video" LoadedBehavior="Manual" UnloadedBehavior="Stop" Stretch="Uniform"/>

    <!-- Capta el click sobre el vídeo (play/pausa) y el doble click (pantalla completa).
         Va por debajo de las capas de control, así que estas reciben los suyos primero. -->
    <Rectangle x:Name="lienzo" Fill="Transparent"/>

    <!-- Si el códec no está soportado, se dice y se ofrece el reproductor del sistema:
         mejor un plan B claro que una pantalla negra sin explicación. -->
    <StackPanel x:Name="panelFallo" Visibility="Collapsed" VerticalAlignment="Center"
                HorizontalAlignment="Center" MaxWidth="460">
      <TextBlock x:Name="lblFallo" TextWrapping="Wrap" TextAlignment="Center" FontSize="12.5"
                 Foreground="{StaticResource Neutral400}" LineHeight="19"/>
      <Button x:Name="btnSistema" Style="{StaticResource BtnPrimary}" Margin="0,14,0,0"
              HorizontalAlignment="Center" Content="Abrir en el reproductor del sistema"/>
    </StackPanel>

    <!-- ══ Capa superior: título y cierre ══ -->
    <Grid x:Name="capaSuperior" VerticalAlignment="Top" Height="88">
      <Grid.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
          <GradientStop Color="#C4000000" Offset="0"/>
          <GradientStop Color="#00000000" Offset="1"/>
        </LinearGradientBrush>
      </Grid.Background>
      <StackPanel Margin="18,11,120,0" VerticalAlignment="Top">
        <TextBlock x:Name="lblTitulo" FontSize="13" FontWeight="SemiBold"
                   TextTrimming="CharacterEllipsis"/>
        <!-- Aviso de fichero en la nube: explica el tirón antes de que desconcierte -->
        <Border x:Name="chipNube" Visibility="Collapsed" Margin="0,6,0,0" CornerRadius="5"
                Background="#382B2741" BorderBrush="{StaticResource Accent700}" BorderThickness="1"
                Padding="8,2.5" HorizontalAlignment="Left">
          <TextBlock x:Name="lblNube" FontSize="10.5" Foreground="{StaticResource Accent300}"/>
        </Border>
      </StackPanel>
      <Button x:Name="btnCerrar" Style="{StaticResource BtnClose}" HorizontalAlignment="Right"
              VerticalAlignment="Top" WindowChrome.IsHitTestVisibleInChrome="True">
        <Path Data="M2,2 L11,11 M11,2 L2,11" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
              StrokeThickness="1.2" Width="13" Height="13" Stretch="None"
              HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Button>
    </Grid>

    <!-- ══ Capa inferior: barra de posición y transporte ══ -->
    <Grid x:Name="capaInferior" VerticalAlignment="Bottom" Height="150">
      <Grid.Background>
        <!-- El velo tiene que empezar a oscurecer ANTES de la fila de tiempos: medido
             sobre un fotograma naranja, el texto de la duración se quedaba en 2,6:1 de
             contraste porque caía por encima de la parte oscura. -->
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
          <GradientStop Color="#00000000" Offset="0"/>
          <GradientStop Color="#BF000000" Offset="0.38"/>
          <GradientStop Color="#F2000000" Offset="1"/>
        </LinearGradientBrush>
      </Grid.Background>

      <Grid Margin="18,0,18,16" VerticalAlignment="Bottom">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- fila 0: tiempo · barra · duración -->
        <Grid Grid.Row="0" Margin="0,0,0,4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock x:Name="lblPos" VerticalAlignment="Center" Margin="0,0,11,0" MinWidth="42"
                     TextAlignment="Right" FontFamily="{StaticResource FontMono}" FontSize="11"
                     Foreground="#D6D9E8" Text="0:00"/>
          <Slider x:Name="barra" Grid.Column="1" Style="{StaticResource BarraVideo}" VerticalAlignment="Center"/>
          <TextBlock x:Name="lblDur" Grid.Column="2" VerticalAlignment="Center" Margin="11,0,0,0" MinWidth="42"
                     FontFamily="{StaticResource FontMono}" FontSize="11"
                     Foreground="#B9BECF" Text="0:00"/>
        </Grid>

        <!-- fila 1: transporte al centro, volumen y pantalla completa a la derecha -->
        <Grid Grid.Row="1">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="btnAtras" Style="{StaticResource BtnIcono}" Margin="0,0,10,0"
                    ToolTip="Atrás 10 s  (flecha izquierda)">
              <Path Data="M10,5 L4.5,10 L10,15 M16,5 L10.5,10 L16,15" Stretch="None" Width="20" Height="20"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                    StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"/>
            </Button>

            <Button x:Name="btnPlay" Style="{StaticResource BtnPlay}" ToolTip="Reproducir / pausar  (espacio)">
              <Path x:Name="glifoPlay" Fill="White" Stretch="None"
                    Data="M6,3 L6,17 M13,3 L13,17" Stroke="White" StrokeThickness="3.2"
                    StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="19" Height="20"/>
            </Button>

            <Button x:Name="btnAdelante" Style="{StaticResource BtnIcono}" Margin="10,0,0,0"
                    ToolTip="Adelante 10 s  (flecha derecha)">
              <Path Data="M10,5 L15.5,10 L10,15 M4,5 L9.5,10 L4,15" Stretch="None" Width="20" Height="20"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                    StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"/>
            </Button>
          </StackPanel>

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <Button x:Name="btnMudo" Style="{StaticResource BtnIcono}" ToolTip="Silenciar  (M)">
              <Path x:Name="glifoVol" Stretch="None" Width="20" Height="20"
                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                    StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeLineJoin="Round"
                    Data="M4,8 L7,8 L11,4.5 L11,15.5 L7,12 L4,12 Z"/>
            </Button>
            <Slider x:Name="volumen" Style="{StaticResource BarraVolumen}" VerticalAlignment="Center"
                    Margin="2,0,8,0" Minimum="0" Maximum="1" Value="0.8"/>
            <Button x:Name="btnPantalla" Style="{StaticResource BtnIcono}" ToolTip="Pantalla completa  (F)">
              <Path x:Name="glifoPantalla" Stretch="None" Width="20" Height="20"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                    StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeLineJoin="Round"
                    Data="M3,7.5 L3,3 L7.5,3 M12.5,3 L17,3 L17,7.5 M17,12.5 L17,17 L12.5,17 M7.5,17 L3,17 L3,12.5"/>
            </Button>
          </StackPanel>
        </Grid>
      </Grid>
    </Grid>
  </Grid>
</Window>
