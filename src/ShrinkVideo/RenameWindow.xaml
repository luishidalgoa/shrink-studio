<Window x:Class="ShrinkVideo.RenameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Renombrar salida" Width="820" Height="640" WindowStyle="None" ResizeMode="CanResize"
        MinWidth="700" MinHeight="520" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="{StaticResource FontUI}" Foreground="{StaticResource Text}" Background="Transparent">
  <Border Background="{StaticResource Bg}" BorderBrush="{StaticResource Divider}" BorderThickness="1" CornerRadius="10">
    <Grid Margin="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/><!-- header -->
        <RowDefinition Height="Auto"/><!-- buscar/reemplazar -->
        <RowDefinition Height="Auto"/><!-- opciones -->
        <RowDefinition Height="Auto"/><!-- variables -->
        <RowDefinition Height="*"/><!-- vista previa -->
        <RowDefinition Height="Auto"/><!-- footer -->
      </Grid.RowDefinitions>

      <!-- header (arrastrable) -->
      <Grid x:Name="header" Grid.Row="0" Height="46" Background="Transparent">
        <TextBlock Text="Renombrar salida" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" Margin="18,0,0,0"/>
        <TextBlock Text="se aplica al archivo comprimido de cada vídeo, según se procesa" FontSize="11"
                   Foreground="{StaticResource Neutral600}" VerticalAlignment="Center" Margin="150,2,0,0"/>
        <Button x:Name="btnX" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"
                Width="30" Height="30" Background="Transparent" BorderThickness="0" Cursor="Hand" Foreground="{StaticResource Neutral500}">
          <Path Data="M2,2 L11,11 M11,2 L2,11" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                StrokeThickness="1.3" Width="13" Height="13" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Button>
      </Grid>

      <!-- Buscar / Reemplazar -->
      <Grid Grid.Row="1" Margin="18,0,18,12">
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
          <TextBlock Text="Buscar" FontSize="11" Foreground="{StaticResource Neutral500}" Margin="0,0,0,4"/>
          <TextBox x:Name="txtSearch"/>
          <Popup x:Name="popSearch" PlacementTarget="{Binding ElementName=txtSearch}" Placement="Bottom"
                 AllowsTransparency="True" StaysOpen="False" Focusable="False" PopupAnimation="Fade"
                 MinWidth="{Binding ActualWidth, ElementName=txtSearch}">
            <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Divider}" BorderThickness="1"
                    CornerRadius="8" Padding="4" Margin="0,3,12,12">
              <Border.Effect><DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.5" Color="#000000"/></Border.Effect>
              <ListBox x:Name="lstSearch" MaxHeight="260" Background="Transparent" BorderThickness="0"
                       ItemContainerStyle="{StaticResource SuggestItem}"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <StackPanel>
                      <TextBlock Text="{Binding Text}" FontFamily="{StaticResource FontMono}" FontSize="11.5" Foreground="{StaticResource Accent300}"/>
                      <TextBlock Text="{Binding Desc}" FontSize="10.5" Foreground="{StaticResource Neutral600}" TextWrapping="Wrap"/>
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>
          </Popup>
        </StackPanel>
        <StackPanel Grid.Column="2">
          <TextBlock Text="Reemplazar por" FontSize="11" Foreground="{StaticResource Neutral500}" Margin="0,0,0,4"/>
          <TextBox x:Name="txtReplace"/>
          <Popup x:Name="popReplace" PlacementTarget="{Binding ElementName=txtReplace}" Placement="Bottom"
                 AllowsTransparency="True" StaysOpen="False" Focusable="False" PopupAnimation="Fade"
                 MinWidth="{Binding ActualWidth, ElementName=txtReplace}">
            <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Divider}" BorderThickness="1"
                    CornerRadius="8" Padding="4" Margin="0,3,12,12">
              <Border.Effect><DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.5" Color="#000000"/></Border.Effect>
              <ListBox x:Name="lstReplace" MaxHeight="260" Background="Transparent" BorderThickness="0"
                       ItemContainerStyle="{StaticResource SuggestItem}"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <StackPanel>
                      <TextBlock Text="{Binding Text}" FontFamily="{StaticResource FontMono}" FontSize="11.5" Foreground="{StaticResource Accent300}"/>
                      <TextBlock Text="{Binding Desc}" FontSize="10.5" Foreground="{StaticResource Neutral600}" TextWrapping="Wrap"/>
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>
          </Popup>
        </StackPanel>
      </Grid>

      <!-- Opciones -->
      <Border Grid.Row="2" Margin="18,0,18,12" Background="{StaticResource Surface}" CornerRadius="8" Padding="12,10">
        <StackPanel>
          <WrapPanel>
            <CheckBox x:Name="chkRegex" Content="Usar expresiones regulares" Margin="0,0,18,6"/>
            <CheckBox x:Name="chkCase" Content="Distinguir mayúsculas y minúsculas" Margin="0,0,18,6"/>
            <CheckBox x:Name="chkAll" Content="Todas las coincidencias" Margin="0,0,18,6"/>
            <CheckBox x:Name="chkEnum" Content="Enumerar elementos" Margin="0,0,18,6"/>
            <CheckBox x:Name="chkRand" Content="Cadenas aleatorias" Margin="0,0,0,6"/>
          </WrapPanel>
          <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
            <TextBlock Text="Aplicar a" FontSize="11" Foreground="{StaticResource Neutral500}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="cboTarget" Width="180" SelectedIndex="0">
              <ComboBoxItem Content="Solo el nombre"/>
              <ComboBoxItem Content="Solo la extensión"/>
              <ComboBoxItem Content="Nombre y extensión"/>
            </ComboBox>
            <TextBlock Text="Formato del texto" FontSize="11" Foreground="{StaticResource Neutral500}" VerticalAlignment="Center" Margin="22,0,8,0"/>
            <ComboBox x:Name="cboCase" Width="200" SelectedIndex="0">
              <ComboBoxItem Content="Sin cambio"/>
              <ComboBoxItem Content="minúsculas"/>
              <ComboBoxItem Content="MAYÚSCULAS"/>
              <ComboBoxItem Content="Primera letra del nombre"/>
              <ComboBoxItem Content="Mayúscula En Cada Palabra"/>
            </ComboBox>
          </StackPanel>
          <TextBlock x:Name="lblExtWarn" Text="Ojo: la extensión determina el formato real del archivo; cambiarla no reconvierte el vídeo."
                     FontSize="10.5" Foreground="#E0B341" TextWrapping="Wrap" Margin="0,8,0,0" Visibility="Collapsed"/>
        </StackPanel>
      </Border>

      <!-- Variables disponibles -->
      <Expander Grid.Row="3" Margin="18,0,18,10" Header="Variables disponibles" Foreground="{StaticResource Neutral500}" FontSize="11.5">
        <Border Background="{StaticResource Field}" CornerRadius="6" Padding="12,10" Margin="0,6,0,0">
          <StackPanel>
            <TextBlock FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource Neutral400}" TextWrapping="Wrap"
                       Text="Contadores (con «Enumerar elementos»):  ${}   ${start=N}   ${increment=N}   ${padding=N}   ·  combinables: ${padding=4;increment=2;start=10}"/>
            <TextBlock FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource Neutral400}" TextWrapping="Wrap" Margin="0,6,0,0"
                       Text="Fecha del original:  $YYYY $YY $Y  $MMMM $MMM $MM $M  $DDDD $DDD $DD $D  $hh $h  $mm $m  $ss $s  $fff $ff $f"/>
            <TextBlock FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource Neutral400}" TextWrapping="Wrap" Margin="0,6,0,0"
                       Text="Regex:  grupos de captura $1 … $9   ·   $$ = un dólar literal"/>
            <TextBlock FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource Neutral400}" TextWrapping="Wrap" Margin="0,6,0,0"
                       Text="Aleatorio (con «Cadenas aleatorias»):  ${rstringalnum=N}  ${rstringalpha=N}  ${rstringdigit=N}  ${ruuidv4}"/>
          </StackPanel>
        </Border>
      </Expander>

      <!-- Vista previa -->
      <Border Grid.Row="4" Margin="18,0,18,0" Background="{StaticResource Surface}" CornerRadius="8" Padding="0,4">
        <DockPanel>
          <Grid DockPanel.Dock="Top" Margin="12,6,12,6">
            <TextBlock Text="VISTA PREVIA" FontSize="10" Foreground="{StaticResource Neutral500}" VerticalAlignment="Center"/>
            <TextBlock x:Name="lblCount" HorizontalAlignment="Right" FontSize="11" Foreground="{StaticResource Neutral500}" VerticalAlignment="Center"/>
          </Grid>
          <ListView x:Name="lstPrev" Style="{StaticResource TableView}" SelectionMode="Single">
            <ListView.View>
              <GridView ColumnHeaderContainerStyle="{StaticResource ColHeader}">
                <GridViewColumn Header="ORIGINAL" Width="360" DisplayMemberBinding="{Binding Original}"/>
                <GridViewColumn Header="NUEVO NOMBRE" Width="380">
                  <GridViewColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Nuevo}" Foreground="{Binding Color}"/>
                    </DataTemplate>
                  </GridViewColumn.CellTemplate>
                </GridViewColumn>
              </GridView>
            </ListView.View>
          </ListView>
        </DockPanel>
      </Border>

      <!-- footer -->
      <Border Grid.Row="5" BorderBrush="{StaticResource Divider}" BorderThickness="0,1,0,0" Padding="18,12" Margin="0,12,0,0">
        <Grid>
          <Button x:Name="btnClear" Style="{StaticResource BtnGhost}" Content="Quitar regla" HorizontalAlignment="Left"
                  ToolTip="Desactiva el renombrado: la salida conservará el nombre original"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnCancel" Style="{StaticResource BtnSecondary}" Content="Cancelar" Width="100" Margin="0,0,8,0"/>
            <Button x:Name="btnApply" Style="{StaticResource BtnPrimary}" Content="Aplicar" Width="110" IsDefault="True"/>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
