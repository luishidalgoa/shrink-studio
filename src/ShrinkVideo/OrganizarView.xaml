<UserControl x:Class="ShrinkVideo.OrganizarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ShrinkVideo"
             FontFamily="{StaticResource FontUI}" Foreground="{StaticResource Text}">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="B2V"/>
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/><!-- barra de contexto -->
      <RowDefinition Height="Auto"/><!-- resumen-filtro -->
      <RowDefinition Height="*"/>   <!-- inicio / revisión -->
      <RowDefinition Height="Auto"/><!-- acciones -->
    </Grid.RowDefinitions>

    <!-- ══════════════ Barra de contexto ══════════════ -->
    <!-- La carpeta ya no vive aquí: se eligió centralizarla en el panel de ficheros,
         que es donde se ve el recuento y donde está «Simular» — tres piezas de la misma
         acción repartidas por la pantalla eran información redundante. -->
    <Grid Grid.Row="0" Margin="16,4,16,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="14"/>
        <ColumnDefinition Width="*" MinWidth="120"/>
      </Grid.ColumnDefinitions>

      <!-- Serie (catálogo de referencia) -->
      <StackPanel Grid.Column="0">
        <TextBlock Text="Serie (catálogo de referencia)" Style="{StaticResource OrgLabel}"/>
        <StackPanel Orientation="Horizontal">
          <!-- ItemTemplate explícito y no DisplayMemberPath: la plantilla propia del tema
               pinta la selección con SelectionBoxItemTemplate, y con DisplayMemberPath se
               quedaba sin plantilla y enseñaba el nombre del tipo. -->
          <ComboBox x:Name="cboSerie" MinWidth="110" MaxWidth="215" Height="34" VerticalContentAlignment="Center"
                    ToolTip="El catálogo contra el que se identifican los ficheros de la carpeta">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Serie}" TextTrimming="CharacterEllipsis"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button x:Name="btnCatalogos" Style="{StaticResource BtnSecondary}" Height="34" Margin="6,0,0,0"
                  Content="Catálogos…"
                  ToolTip="Importar, revisar o quitar catálogos de referencia"/>
          <!-- Verificar una propuesta sin abrir el JSON a mano: busca por número o título -->
          <Button x:Name="btnExplorar" Style="{StaticResource BtnSecondary}" Width="34" Height="34" Padding="0"
                  Margin="6,0,0,0" ToolTip="Explorar el catálogo elegido: busca por número o por título para comprobar una propuesta">
            <Viewbox Width="14" Height="14">
              <Path Data="M6.5 2a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9z M9.8 9.8 L13.5 13.5"
                    Stroke="{StaticResource Text}" StrokeThickness="1.4" StrokeStartLineCap="Round"/>
            </Viewbox>
          </Button>
        </StackPanel>
      </StackPanel>

      <!-- Plantilla de biblioteca -->
      <StackPanel Grid.Column="2">
        <TextBlock Text="Plantilla de biblioteca" Style="{StaticResource OrgLabel}"/>
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
          <local:CampoTexto x:Name="txtPlantilla" HorizontalAlignment="Stretch" MinWidth="90"
                            FontFamily="{StaticResource FontMono}" FontSize="11.5"
                            Foreground="{StaticResource Neutral400}"
                            ToolTip="Cómo se compone el nombre final. No es el «Renombrado libre» de Herramientas: aquí el nombre se construye desde el catálogo."/>
          <!-- «Editar» no hacía nada que no hiciera pinchar en el propio campo. En su sitio,
               un desplegable que inserta las marcas y explica qué es cada una. -->
          <ToggleButton x:Name="btnMarcas" Grid.Column="1" Style="{StaticResource FiltroChip}"
                        Margin="6,0,0,0" Padding="10,7" VerticalAlignment="Center"
                        ToolTip="Insertar una marca en la plantilla">
            <TextBlock><Run Text="Marcas"/><Run Text=" ▾" Foreground="{StaticResource Neutral500}"/></TextBlock>
          </ToggleButton>

          <Popup x:Name="popMarcas" PlacementTarget="{Binding ElementName=btnMarcas}" Placement="Bottom"
                 IsOpen="{Binding IsChecked, ElementName=btnMarcas, Mode=TwoWay}"
                 StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" HorizontalOffset="-260">
            <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Neutral800}"
                    BorderThickness="1" CornerRadius="8" Padding="6" Margin="0,4,12,12" MaxWidth="420">
              <StackPanel>
                <TextBlock Text="Se inserta donde tengas el cursor" Style="{StaticResource OrgMuted}"
                           FontSize="11" Margin="8,4,8,6"/>
                <ItemsControl x:Name="listaMarcas">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Style="{StaticResource BtnGhostMuted}" HorizontalContentAlignment="Stretch"
                              Padding="8,6" Click="OnInsertarMarca" Tag="{Binding Marca}">
                        <StackPanel>
                          <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Marca}" FontFamily="{StaticResource FontMono}"
                                       FontSize="12" Foreground="{StaticResource Accent}"/>
                            <TextBlock Text="{Binding Nombre}" Margin="10,0,0,0" FontSize="12"
                                       Foreground="{StaticResource Text}"/>
                          </StackPanel>
                          <TextBlock Text="{Binding Descripcion}" FontSize="11.5" TextWrapping="Wrap"
                                     Foreground="{StaticResource Neutral500}" Margin="0,2,0,0"/>
                        </StackPanel>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </Popup>
        </Grid>

        <!-- Cómo queda de verdad, con un episodio real del catálogo elegido: sin esto hay
             que aplicar para descubrir qué produce la plantilla. -->
        <TextBlock x:Name="lblVistaPrevia" Margin="0,5,0,0" FontSize="11" TextTrimming="CharacterEllipsis"
                   Foreground="{StaticResource Neutral500}" ToolTip="Ejemplo con un episodio real del catálogo"/>
      </StackPanel>
    </Grid>

    <!-- ══════════════ Resumen-filtro (solo en revisión) ══════════════ -->
    <Grid x:Name="filaChips" Grid.Row="1" Margin="16,0,16,10" Visibility="Collapsed">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <!-- WrapPanel: los chips bajan de linea en vez de meterse debajo de los botones. -->
      <WrapPanel Orientation="Horizontal" x:Name="panelChips">
        <!-- Sin esto, una vez simulas te quedas en la tabla para siempre: no había forma de
             volver a la pantalla limpia salvo cambiar de página y regresar. -->
        <Button x:Name="btnVolver" Style="{StaticResource BtnSecondary}" FontSize="11.5"
                Padding="9,4" Margin="0,0,10,0" Content="← Volver"
                ToolTip="Descartar este análisis y volver a la pantalla de inicio"/>
        <ToggleButton x:Name="chipLimpios" Style="{StaticResource FiltroChip}">
          <TextBlock><Run Text="●" Foreground="#86D8A6"/><Run x:Name="runLimpios" Text=" 0 correctos"/></TextBlock>
        </ToggleButton>
        <ToggleButton x:Name="chipCorregidos" Style="{StaticResource FiltroChip}">
          <TextBlock><Run Text="↻" Foreground="#86D8A6"/><Run x:Name="runCorregidos" Text=" 0 con cambios"/></TextBlock>
        </ToggleButton>
        <ToggleButton x:Name="chipEspeciales" Style="{StaticResource FiltroChip}">
          <TextBlock><Run Text="▲" Foreground="#E3C36B"/><Run x:Name="runEspeciales" Text=" 0 especiales"/></TextBlock>
        </ToggleButton>
        <ToggleButton x:Name="chipConflictos" Style="{StaticResource FiltroChip}">
          <TextBlock><Run Text="◆" Foreground="#EC9AA0"/><Run x:Name="runConflictos" Text=" 0 conflictos"/></TextBlock>
        </ToggleButton>
        <ToggleButton x:Name="chipErrores" Style="{StaticResource FiltroChip}">
          <TextBlock><Run Text="✕" Foreground="#EC9AA0"/><Run x:Name="runErrores" Text=" 0 errores"/></TextBlock>
        </ToggleButton>
        <ToggleButton x:Name="chipDudas" Style="{StaticResource FiltroChip}" Content="Solo dudas" Margin="6,0,0,0"
                      ToolTip="Deja solo lo que necesita que decidas tú"/>
      </WrapPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
        <!-- Buscar dentro de la tabla (Ctrl+K). Filtra por el nombre original Y por la
             propuesta, con la misma normalización del identificador: sin tildes y a medias. -->
        <local:CampoTexto x:Name="txtBuscarTabla" Width="200" Margin="0,0,8,0"
                          Icono="M6.5 2a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9z M9.8 9.8 L13.5 13.5"
                          ToolTip="Buscar en la tabla (Ctrl+K): por nombre original o por propuesta. Esc lo limpia."/>
        <Button x:Name="btnAceptarVerdes" Style="{StaticResource BtnSecondary}" Content="Aceptar verdes"
                Padding="10,5" FontSize="12"
                ToolTip="Da por buenas todas las filas identificadas con confianza"/>
        <Button x:Name="btnConfirmarEspeciales" Style="{StaticResource BtnSecondary}" Content="Confirmar especiales…"
                Padding="10,5" FontSize="12" Margin="8,0,0,0"
                ToolTip="Revisa uno a uno los especiales, que nunca se aplican solos"/>
      </StackPanel>
    </Grid>

    <!-- ══════════════ INICIO: catálogos + ficheros ══════════════ -->
    <Grid x:Name="vistaInicio" Grid.Row="2" Margin="16,0,16,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Catálogos importados -->
      <Border Grid.Column="0" Background="{StaticResource SurfaceGlass}" CornerRadius="8" Padding="14,12">
        <Grid>
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="lblTituloCatalogos" Text="CATÁLOGOS IMPORTADOS" FontSize="11" FontWeight="Medium"
                       Margin="0,0,8,0" Foreground="{StaticResource Neutral500}" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
            <!-- La ayuda del formato va SIEMPRE visible, no solo cuando no hay catálogos:
                 la duda «¿y esto cómo se escribe?» aparece justo al ir a importar. -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
              <Button x:Name="btnFormato" Style="{StaticResource BtnGhost}" Padding="8,5" FontSize="12"
                      Content="¿Qué formato?" Margin="0,0,8,0"
                      ToolTip="Abre la especificación del catálogo: campos, reglas y un ejemplo completo"/>
              <Button x:Name="btnEjemplo" Style="{StaticResource BtnSecondary}" Padding="10,5" FontSize="12"
                      Content="Crear ejemplo…" Margin="0,0,8,0"
                      ToolTip="Guarda un catálogo de ejemplo válido para que lo edites con tus episodios"/>
              <Button x:Name="btnPrompt" Style="{StaticResource BtnSecondary}" Padding="10,5" FontSize="12"
                      Content="Generar con IA…" Margin="0,0,8,0"
                      ToolTip="Arma el encargo para que una IA convierta un anexo de episodios (Wikipedia, Fandom…) en un catálogo"/>
              <Button x:Name="btnImportar" Style="{StaticResource BtnSecondary}"
                      Padding="10,5" FontSize="12"
                      ToolTip="Añadir un catálogo de referencia en formato JSON (esquema reindex/1.0)">
                <StackPanel Orientation="Horizontal">
                  <Viewbox Width="13" Height="13" Margin="0,0,6,0">
                    <Path Data="M8 2v8M5 7l3 3 3-3M2.5 13h11" Stroke="{StaticResource Text}" StrokeThickness="1.4"
                          StrokeStartLineCap="Round" StrokeLineJoin="Round"/>
                  </Viewbox>
                  <TextBlock Text="Importar JSON" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </Grid>

          <!-- Horizontal en «Disabled», no en «Hidden»: con Hidden el contenido se mide con
               ancho infinito y las advertencias nunca llegan a ajustarse — se cortaban. -->
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
              <ItemsControl x:Name="listaCatalogos">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <!-- Tarjeta de catálogo. Las ADVERTENCIAS van dentro y siempre visibles:
                         son lo que evita que el usuario confíe de más en el resultado. -->
                    <Border Style="{StaticResource OrgCard}" Background="{Binding Fondo}"
                            BorderBrush="{Binding Borde}">
                      <!-- El clic derecho lleva AL FICHERO: la app ya no guarda copia, así
                           que ver dónde vive y poder saltar ahí es parte del trato. -->
                      <Border.ContextMenu>
                        <ContextMenu>
                          <MenuItem Header="Abrir la ubicación del fichero"
                                    Click="OnUbicacionCatalogo" Tag="{Binding Cat.Ruta}"/>
                          <MenuItem Header="Copiar la ruta"
                                    Click="OnCopiarRutaCatalogo" Tag="{Binding Cat.Ruta}"/>
                        </ContextMenu>
                      </Border.ContextMenu>
                      <StackPanel>
                        <Grid Margin="0,0,0,6">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <!-- El texto tiene SU columna y se recorta. Grid y NO StackPanel
                               horizontal: el StackPanel mide con ancho infinito, el recorte
                               nunca actúa y el texto seguía corriendo bajo los botones —
                               la misma trampa que ya mordió tres veces en este fichero. -->
                          <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Cat.Serie}" FontSize="13.5" FontWeight="Medium"
                                       Foreground="{StaticResource Text}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Cat.Resumen}" Style="{StaticResource OrgMuted}"
                                       FontSize="11.5" Margin="10,1,8,0" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                          </Grid>
                          <!-- Los tres en UNA fila. Antes iban alineados a la derecha en la
                               misma celda: «seleccionado» y «Usar» son excluyentes y no
                               chocaban, pero «Quitar» sale siempre y quedaba encima de ambos.
                               Con fondo sólido, además: transparentes sobre el título de al
                               lado no había quien los leyera. -->
                          <StackPanel Orientation="Horizontal" Grid.Column="1"
                                      VerticalAlignment="Center">
                            <Border Background="{StaticResource Accent800}" CornerRadius="6" Padding="8,2"
                                    Margin="0,0,6,0" VerticalAlignment="Center"
                                    Visibility="{Binding Seleccionado, Converter={StaticResource B2V}}">
                              <TextBlock Text="seleccionado" FontSize="10.5"
                                         Foreground="{StaticResource Accent200}"/>
                            </Border>
                            <Button Content="Usar" Style="{StaticResource BtnCristal}" FontSize="11.5"
                                    Padding="10,3" Margin="0,0,6,0" Tag="{Binding Cat.Ruta}"
                                    Click="OnUsarCatalogo"
                                    Visibility="{Binding NoSeleccionado, Converter={StaticResource B2V}}"/>
                            <Button Style="{StaticResource BtnCristal}" FontSize="11.5" Padding="10,3"
                                    Content="Quitar" Tag="{Binding Cat.Ruta}"
                                    Click="OnQuitarCatalogo"
                                    ToolTip="Quitar este catálogo de la app (no borra tu fichero JSON)"/>
                          </StackPanel>
                        </Grid>

                        <!-- Dónde vive el JSON que la app lee (ya no hay copia). Es un botón:
                             pulsar abre la carpeta con el fichero seleccionado. -->
                        <Button Style="{StaticResource BtnGhostMuted}" Padding="0" Margin="0,0,0,6"
                                HorizontalAlignment="Left" HorizontalContentAlignment="Left"
                                Click="OnUbicacionCatalogo" Tag="{Binding Cat.Ruta}"
                                ToolTip="{Binding Cat.ProcedenciaDetalle}">
                          <TextBlock Text="{Binding Cat.Procedencia}" Style="{StaticResource OrgMuted}"
                                     FontSize="11" TextTrimming="CharacterEllipsis"/>
                        </Button>
                        <ItemsControl ItemsSource="{Binding Cat.Advertencias}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <!-- Grid y no StackPanel horizontal: un StackPanel horizontal mide a
                                   sus hijos con ancho infinito, así que TextWrapping no llega a
                                   actuar nunca y la advertencia salía cortada. -->
                              <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="▲" Foreground="{StaticResource OrgWarn}" FontSize="10.5"
                                           Margin="0,1,6,0" VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="1" Text="{Binding}" Foreground="{StaticResource OrgWarn}"
                                           FontSize="11.5" TextWrapping="Wrap"/>
                              </Grid>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <!-- Sin catálogos: se explica qué es antes de pedir nada -->
              <StackPanel x:Name="panelSinCatalogos" Margin="0,10,0,0" Visibility="Collapsed">
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Neutral400}" FontSize="12.5" LineHeight="19">
                  Un <Run FontWeight="Medium" Foreground="{StaticResource Text}">catálogo</Run> es la lista de
                  episodios de una serie: número, fecha de emisión y títulos. ShrinkStudio compara tus ficheros
                  con esa lista para saber qué episodio es cada uno.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Neutral500}" FontSize="12"
                           Margin="0,10,0,0" LineHeight="18">
                  Es un archivo JSON con el esquema <Run FontFamily="{StaticResource FontMono}">reindex/1.0</Run>.
                  Sin catálogo no hay nada con lo que comparar, así que el análisis queda deshabilitado.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Neutral500}" FontSize="12"
                           Margin="0,10,0,0" LineHeight="18">
                  Lo mínimo es la serie y una lista de episodios con su número y su título; la fecha de
                  emisión no hace falta, pero es la pista más fiable que hay. Pulsa
                  <Run FontWeight="Medium" Foreground="{StaticResource Accent}">Crear ejemplo…</Run> para
                  partir de uno válido, o <Run FontWeight="Medium" Foreground="{StaticResource Accent}">¿Qué formato?</Run>
                  para ver todos los campos y las reglas.
                </TextBlock>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- Ficheros -->
      <Border Grid.Column="2" Background="{StaticResource SurfaceGlass}" CornerRadius="8" Padding="14,12">
        <Grid>
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="FICHEROS" FontSize="11" FontWeight="Medium"
                     Foreground="{StaticResource Neutral500}" Margin="0,0,0,12"/>

          <Grid Grid.Row="1">
            <!-- Trazo discontinuo del diseño: marca «aquí falta algo» sin pesar como un marco
                 sólido. Border no sabe hacer guiones, así que va un Rectangle detrás. -->
            <Rectangle Stroke="{StaticResource Neutral800}" StrokeThickness="1" RadiusX="8" RadiusY="8"
                       StrokeDashArray="4 3" SnapsToDevicePixels="True"/>
            <!-- El haz que rodea el panel mientras identifica. Lo enciende el código. -->
            <Border x:Name="hazFicheros" Style="{StaticResource HazDeBorde}" CornerRadius="8">
              <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                  <LinearGradientBrush.RelativeTransform>
                    <RotateTransform CenterX="0.5" CenterY="0.5"/>
                  </LinearGradientBrush.RelativeTransform>
                  <GradientStop Color="#00968AE0" Offset="0.00"/>
                  <GradientStop Color="#33968AE0" Offset="0.34"/>
                  <GradientStop Color="#FFD2CEFD" Offset="0.50"/>
                  <GradientStop Color="#33968AE0" Offset="0.66"/>
                  <GradientStop Color="#00968AE0" Offset="1.00"/>
                </LinearGradientBrush>
              </Border.BorderBrush>
            </Border>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="340" Margin="18,0">

              <!-- La carpeta vive AQUÍ: elegirla, ver cuántos ficheros trae y simular son la
                   misma acción, y estaban repartidas por tres sitios de la pantalla. -->
              <TextBlock Text="Carpeta a organizar" Style="{StaticResource OrgLabel}"/>
              <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <local:CampoTexto x:Name="txtCarpeta" Icono="M1.5 3.5h4l1.5 2h7.5v7h-13z" HorizontalAlignment="Stretch"/>
                <Button x:Name="btnCarpeta" Grid.Column="1" Style="{StaticResource BtnSecondary}" Width="34" Height="34" Padding="0"
                        Margin="6,0,0,0" ToolTip="Elegir la carpeta cuyos ficheros quieres organizar">
                  <Viewbox Width="15" Height="15">
                    <Path Data="M1.5 3.5h4l1.5 2h7.5l-2 7h-11z M1.5 3.5v9h11" Stroke="{StaticResource Text}" StrokeThickness="1.4" StrokeLineJoin="Round"/>
                  </Viewbox>
                </Button>
              </Grid>

              <TextBlock x:Name="lblFicheros" Text="Elige una carpeta para empezar" FontSize="13.5"
                         Foreground="{StaticResource Text}" HorizontalAlignment="Center" TextAlignment="Center"
                         TextWrapping="Wrap"/>

              <!-- Reposo: promesa + botón. Se retiran mientras corren las etapas. -->
              <StackPanel x:Name="panelReposo">
                <!-- La promesa explícita: nada se toca sin aprobación. Es lo que permite
                     pulsar «Simular» sin miedo. -->
                <TextBlock Margin="0,10,0,0" FontSize="12" Foreground="{StaticResource Neutral500}"
                           TextAlignment="Center" TextWrapping="Wrap" LineHeight="18">
                  Nada se renombra sin tu aprobación: <Run FontWeight="Medium" Foreground="{StaticResource Neutral400}">Analizar</Run>
                  solo lee los nombres y propone. Después revisas y aplicas.
                </TextBlock>
                <Button x:Name="btnSimularGrande" Style="{StaticResource BtnPrimary}" Margin="0,18,0,0"
                        HorizontalAlignment="Center" IsEnabled="False">
                  <StackPanel Orientation="Horizontal">
                    <Viewbox Width="14" Height="14" Margin="0,0,6,0">
                      <Canvas Width="16" Height="16">
                        <Ellipse Width="9" Height="9" Canvas.Left="2.5" Canvas.Top="2.5" Stroke="#968AE0" StrokeThickness="1.5"/>
                        <Path Data="M10.5 10.5L14 14" Stroke="#968AE0" StrokeThickness="1.5" StrokeStartLineCap="Round"/>
                      </Canvas>
                    </Viewbox>
                    <TextBlock Text="Analizar la carpeta" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
              </StackPanel>

              <!-- Etapas de la identificación. Los iconos los conmuta el código:
                   círculo discontinuo (pendiente) → arco girando (en curso) → check que se
                   dibuja y da un pequeño salto (hecha). -->
              <StackPanel x:Name="panelEtapas" Margin="0,16,0,0" Visibility="Collapsed"/>
            </StackPanel>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <!-- ══════════════ REVISIÓN: la tabla de triaje ══════════════ -->
    <Grid x:Name="vistaRevision" Grid.Row="2" Margin="16,0,16,0" Visibility="Collapsed">
      <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>

      <!-- Banner de aviso cuando el lote viene mayoritariamente dudoso -->
      <Border x:Name="bannerAviso" Grid.Row="0" Background="{StaticResource OrgWarnBg}"
              BorderBrush="{StaticResource OrgWarnBorder}" BorderThickness="1" CornerRadius="8"
              Padding="12,9" Margin="0,0,0,10" Visibility="Collapsed">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="▲" Foreground="{StaticResource OrgWarn}" VerticalAlignment="Top" Margin="0,1,9,0"/>
          <TextBlock x:Name="lblBannerAviso" Foreground="{StaticResource OrgWarn}" FontSize="12.5"
                     TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <!-- Banda de resultado tras aplicar -->
      <Border x:Name="bannerAplicado" Grid.Row="0" Background="{StaticResource OrgOkBg}"
              BorderBrush="{StaticResource OrgOkBorder}" BorderThickness="1" CornerRadius="8"
              Padding="12,9" Margin="0,0,0,10" Visibility="Collapsed">
        <Grid>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="✓" Foreground="{StaticResource OrgOk}" VerticalAlignment="Center" Margin="0,0,9,0"/>
            <TextBlock x:Name="lblBannerAplicado" Foreground="{StaticResource OrgOk}" FontSize="12.5"
                       VerticalAlignment="Center"/>
          </StackPanel>
          <Button x:Name="btnDeshacerBanda" Style="{StaticResource BtnGhost}" HorizontalAlignment="Right"
                  Content="Deshacer este lote" FontSize="12"/>
        </Grid>
      </Border>

      <Border Grid.Row="1" Background="{StaticResource SurfaceGlass}" CornerRadius="8" ClipToBounds="True">
        <!-- El resolutor se despliega al seleccionar la fila; el propio detalle se oculta
             para las filas que no tienen nada que resolver. -->
        <!-- La separación por temporada la pinta cada fila (ver «banda» en OrgRow), no
             DataGrid.GroupStyle: agrupar rompe el reparto de las columnas en «*». -->
        <DataGrid x:Name="tabla" Style="{StaticResource OrgGrid}"
                  RowDetailsVisibilityMode="VisibleWhenSelected">
          <!-- Va en la tabla y no en el estilo de fila: el estilo vive en un diccionario
               de recursos, que no tiene código detrás donde colgar los manejadores. La
               fila sobre la que se pulsó se resuelve al abrirlo. -->
          <DataGrid.ContextMenu>
            <ContextMenu x:Name="menuFila">
              <MenuItem x:Name="miReproducir" Header="Reproducir"/>
              <MenuItem x:Name="miRecortar" Header="Enviar a Recortes…"/>
              <MenuItem x:Name="miUbicacion" Header="Abrir la ubicación del fichero"/>
              <Separator/>
              <!-- Encontrar un fichero problemático cuesta más que arreglarlo: esto lo
                   aparta para mañana sin tener que volver a buscarlo. -->
              <MenuItem x:Name="miRevisar" Header="Apartar para revisar luego"/>
            </ContextMenu>
          </DataGrid.ContextMenu>
          <DataGrid.Columns>

            <!-- Marcar qué se aplica. Solo tiene casilla lo que ESTÁ listo: poner una en
                 los conflictos insinuaría que marcándolos se aplican, y es al revés. -->
            <DataGridTemplateColumn Width="44">
              <DataGridTemplateColumn.Header>
                <CheckBox x:Name="chkTodos" IsChecked="True" Checked="OnMarcarTodos" Unchecked="OnMarcarTodos"
                          ToolTip="Marcar o desmarcar todos los listos para aplicar"/>
              </DataGridTemplateColumn.Header>
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <CheckBox IsChecked="{Binding Marcado, UpdateSourceTrigger=PropertyChanged}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Checked="OnMarcarFila" Unchecked="OnMarcarFila"
                            Visibility="{Binding ListoParaAplicar, Converter={StaticResource B2V}}"
                            ToolTip="Aplicar el renombrado a este fichero"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- ESTADO — chip: glifo + palabra + color, nunca solo color -->
            <DataGridTemplateColumn Header="ESTADO" Width="112">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Border Background="{Binding EstadoBg}" BorderBrush="{Binding EstadoBorde}" BorderThickness="1"
                          CornerRadius="6" Padding="8,3" HorizontalAlignment="Left">
                    <Border.ToolTip>
                      <TextBlock Text="{Binding EstadoTooltip}" MaxWidth="360" TextWrapping="Wrap"/>
                    </Border.ToolTip>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding EstadoGlifo}" Foreground="{Binding EstadoFg}" FontSize="10.5"
                                 VerticalAlignment="Center" Margin="0,0,5,0"/>
                      <TextBlock Text="{Binding EstadoTexto}" Foreground="{Binding EstadoFg}" FontSize="11.5"
                                 VerticalAlignment="Center"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- APARTADO — sin encabezado ni anchura fija: es un margen de libreta, no una
                 columna de datos. Solo aparece si hay algo apartado. -->
            <DataGridTemplateColumn Width="Auto">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="🔖" FontSize="12" Margin="0,0,2,0" VerticalAlignment="Center"
                             Visibility="{Binding VerApartada}" ToolTip="En la cola"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- FICHERO ORIGINAL -->
            <DataGridTemplateColumn Header="FICHERO ORIGINAL" Width="1.1*">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Original}" Foreground="{StaticResource Neutral300}"
                             TextTrimming="CharacterEllipsis" ToolTip="{Binding Res.Archivo.Path}"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- PROPUESTA -->
            <DataGridTemplateColumn Header="PROPUESTA" Width="1.6*">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Propuesta}" Foreground="{Binding PropuestaFg}"
                             TextTrimming="CharacterEllipsis" ToolTip="{Binding Propuesta}">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Style.Triggers>
                          <!-- Solo se destaca lo que de verdad va a cambiar -->
                          <DataTrigger Binding="{Binding PropuestaDestacada}" Value="True">
                            <Setter Property="FontWeight" Value="Medium"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- POR QUÉ — evidencia corta; la prosa completa, en el tooltip -->
            <DataGridTemplateColumn Header="POR QUÉ" Width="0.7*" MinWidth="90">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding PorQue}" Foreground="{StaticResource Neutral500}" FontSize="12"
                             TextTrimming="CharacterEllipsis" ToolTip="{Binding Explicacion}"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>

          <!-- ══ Resolutor de conflictos, desplegado BAJO la fila ══ -->
          <DataGrid.RowDetailsTemplate>
            <DataTemplate>
              <Border Background="{StaticResource Bg}" BorderBrush="{StaticResource Divider}" BorderThickness="0,1,0,1"
                      Padding="16,14"
                      Visibility="{Binding TieneDetalle, Converter={StaticResource B2V}}">
                <StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="{Binding TituloDetalle}" FontSize="11" FontWeight="Medium"
                               Foreground="{StaticResource Accent400}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Original}" FontSize="12.5" Foreground="{StaticResource Text}"
                               Margin="12,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Explicacion}" Style="{StaticResource OrgMuted}"
                               Margin="10,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                  </StackPanel>

                  <!-- Tarjetas de candidato, con la evidencia a favor y en contra -->
                  <!-- Se listan los Candidatos de la fila, no las alternativas del motor: esa
                       lista incluye al elegido, que antes no se enseñaba y hacía que las dos
                       opciones ofrecidas parecieran las dos equivocadas. -->
                  <!-- El selector de candidatos se esconde cuando el fichero trae dos
                       episodios: elegir uno es precisamente el error. En su lugar manda el
                       botón «Partirlo en dos…» de abajo. -->
                  <ItemsControl ItemsSource="{Binding Candidatos}" Visibility="{Binding VerSelector}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border x:Name="tarjeta" Background="{StaticResource Surface}" BorderBrush="{StaticResource Divider}"
                                BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,10,0">
                          <StackPanel>
                            <Grid Margin="0,0,0,8">
                              <TextBlock Text="{Binding Cabecera}" VerticalAlignment="Center" FontSize="13"
                                         FontWeight="Medium" Foreground="{StaticResource Text}"/>
                              <Border x:Name="insignia" HorizontalAlignment="Right" VerticalAlignment="Center"
                                      Background="{StaticResource Field}" CornerRadius="6" Padding="8,2">
                                <TextBlock Text="{Binding Etiqueta}" FontSize="10.5"
                                           Foreground="{StaticResource Neutral400}"/>
                              </Border>
                            </Grid>
                            <TextBlock Text="{Binding Titulo}" Style="{StaticResource OrgMuted}"
                                       TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding Evidencia}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <TextBlock Text="{Binding}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4"
                                             Foreground="{StaticResource Neutral400}"/>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- La consecuencia, a la vista: qué nombre quedaría si eliges esta.
                                 Sin esto hay que decidir a ciegas. -->
                            <TextBlock Text="Quedaría como:" FontSize="10.5" Margin="0,8,0,3"
                                       Foreground="{StaticResource Neutral500}"/>
                            <Border Background="{StaticResource Field}" CornerRadius="6" Padding="8,6">
                              <TextBlock Text="{Binding NombreResultante}" FontSize="11.5" TextWrapping="Wrap"
                                         Foreground="{StaticResource Neutral300}"
                                         FontFamily="{StaticResource FontMono}"/>
                            </Border>

                            <Button Style="{StaticResource BtnSecondary}" HorizontalAlignment="Left" Margin="0,10,0,0"
                                    FontSize="12" Padding="10,5" Click="OnElegirCandidato" Tag="{Binding Episodio}"
                                    Content="{Binding TextoBoton}"/>
                          </StackPanel>
                        </Border>
                        <DataTemplate.Triggers>
                          <!-- La propuesta actual se distingue de un vistazo -->
                          <DataTrigger Binding="{Binding EsElegido}" Value="True">
                            <Setter TargetName="tarjeta" Property="BorderBrush" Value="{StaticResource Accent700}"/>
                            <Setter TargetName="tarjeta" Property="Background" Value="{StaticResource Accent900}"/>
                            <Setter TargetName="insignia" Property="Background" Value="{StaticResource Accent800}"/>
                          </DataTrigger>
                        </DataTemplate.Triggers>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <CheckBox x:Name="chkRecordar" Content="Recordar esta decisión para este fichero"
                              Foreground="{StaticResource Neutral400}" FontSize="12" VerticalAlignment="Center"
                              Visibility="{Binding VerSelector}"/>
                    <!-- Un fichero con dos episodios dentro no se arregla eligiendo número:
                         hay que partirlo. Por eso este botón va el PRIMERO y destacado
                         cuando toca — es la única salida real, no una alternativa más. -->
                    <Button Content="Partirlo en dos…" Style="{StaticResource BtnPrimary}" FontSize="12"
                            Padding="12,4" Margin="16,0,0,0" Click="OnPartirEnDos"
                            Visibility="{Binding VerRecortar}"
                            ToolTip="Lo abre en Recortes con un corte ya puesto, listo para ajustarlo"/>
                    <!-- Visible SIEMPRE, también cuando la app recomienda partir: aunque
                         detecte «dos episodios», el usuario puede querer asignar uno a mano
                         (p. ej. si la detección fue un falso positivo). Es la vía de escape.
                         Va en estilo discreto para no competir con «Partirlo en dos…». -->
                    <Button Content="Elegir otro episodio…" Style="{StaticResource BtnGhost}" FontSize="12"
                            Margin="16,0,0,0" Click="OnElegirAMano"/>
                    <Button Content="Dejarlo como está" Style="{StaticResource BtnGhost}" FontSize="12"
                            Margin="8,0,0,0" Click="OnDejarComoEsta"/>
                  </StackPanel>
                </StackPanel>
              </Border>
            </DataTemplate>
          </DataGrid.RowDetailsTemplate>
        </DataGrid>
      </Border>
    </Grid>

    <!-- ══════════════ Barra de acciones ══════════════ -->
    <Grid Grid.Row="3" Margin="16,10,16,8">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <WrapPanel Orientation="Horizontal">
        <Button x:Name="btnSimular" Style="{StaticResource BtnPrimary}" Margin="0,0,8,0" IsEnabled="False"
                ToolTip="Lee los nombres y propone. No toca ningún fichero.">
          <StackPanel Orientation="Horizontal">
            <Viewbox Width="14" Height="14" Margin="0,0,6,0">
              <Canvas Width="16" Height="16">
                <Ellipse Width="9" Height="9" Canvas.Left="2.5" Canvas.Top="2.5" Stroke="#968AE0" StrokeThickness="1.5"/>
                <Path Data="M10.5 10.5L14 14" Stroke="#968AE0" StrokeThickness="1.5" StrokeStartLineCap="Round"/>
              </Canvas>
            </Viewbox>
            <TextBlock Text="Analizar" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <Button x:Name="btnAplicar" Style="{StaticResource BtnPrimary}" Margin="0,0,8,0" IsEnabled="False"
                ToolTip="Renombra solo lo identificado con confianza y lo que hayas confirmado. Las dudas se quedan como están.">
          <StackPanel Orientation="Horizontal">
            <Viewbox Width="14" Height="14" Margin="0,0,6,0">
              <Path Data="M2.5 8.5l4 4 7-9" Stroke="#968AE0" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeLineJoin="Round"/>
            </Viewbox>
            <TextBlock x:Name="lblAplicar" Text="Aplicar" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <Button x:Name="btnDeshacer" Style="{StaticResource BtnGhostMuted}" IsEnabled="False"
                ToolTip="Devuelve los ficheros del último lote a su nombre anterior">
          <StackPanel Orientation="Horizontal">
            <Viewbox Width="14" Height="14" Margin="0,0,6,0">
              <Path Data="M3 8a5 5 0 1 1 1.6 3.7M3 4.5V8h3.5" Stroke="{StaticResource Neutral500}" StrokeThickness="1.4"
                    StrokeStartLineCap="Round" StrokeLineJoin="Round"/>
            </Viewbox>
            <TextBlock x:Name="lblDeshacer" Text="Deshacer último lote" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </WrapPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
        <TextBlock x:Name="lblEstadoOrg" Text="Elige una carpeta y un catálogo" VerticalAlignment="Center"
                   FontSize="12" Foreground="{StaticResource Neutral500}" Margin="0,0,12,0"
                   MaxWidth="360" TextTrimming="CharacterEllipsis"/>
        <!-- La cola no es un filtro de la tabla: es una LISTA APARTE que se abre y se
             mira, como la cola de reproducción de un reproductor de música. Por eso es un
             botón con su desplegable y no un chip que esconde filas. -->
        <!-- FiltroChip y no BtnGhostMuted: aquel apunta a ToggleButton y este a Button, y
             la cola necesita quedarse pulsada mientras su lista está abierta. -->
        <ToggleButton x:Name="btnCola" Style="{StaticResource FiltroChip}" Padding="10,5" Margin="8,0,0,0"
                      ToolTip="La cola: lo que has guardado para mirar luego. Sobrevive al cierre de la app.">
          <TextBlock><Run Text="☰" Foreground="#C9A0FF"/><Run x:Name="runCola" Text=" Cola"/></TextBlock>
        </ToggleButton>

        <Popup x:Name="popCola" PlacementTarget="{Binding ElementName=btnCola}" Placement="Top"
               IsOpen="{Binding IsChecked, ElementName=btnCola, Mode=TwoWay}"
               StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
          <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Neutral800}"
                  BorderThickness="1" CornerRadius="8" Padding="0" Margin="0,12,12,4"
                  Width="440" MaxHeight="420">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>

              <TextBlock Grid.Row="0" Margin="14,12,14,8" FontSize="11" FontWeight="Medium"
                         Foreground="{StaticResource Neutral500}" Text="EN LA COLA"/>

              <TextBlock x:Name="lblColaVacia" Grid.Row="1" Margin="14,4,14,14" FontSize="12"
                         TextWrapping="Wrap" Foreground="{StaticResource Neutral500}"
                         Text="Todavía no hay nada. Con el botón derecho sobre un fichero, «Añadir a la cola»."/>

              <ScrollViewer x:Name="visorCola" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                            Visibility="Collapsed">
                <ItemsControl x:Name="listaCola">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="6,1,6,1">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- La fila entera lleva a ese fichero: es lo que se quiere hacer
                             el 99 % de las veces al abrir la cola. -->
                        <Button Grid.Column="0" Style="{StaticResource BtnGhostMuted}" Padding="8,6"
                                HorizontalContentAlignment="Stretch" Click="OnIrAFicheroDeLaCola"
                                Tag="{Binding Ruta}" ToolTip="{Binding Ruta}">
                          <StackPanel>
                            <TextBlock Text="{Binding Nombre}" FontSize="12.5" TextTrimming="CharacterEllipsis"
                                       Foreground="{StaticResource Text}"/>
                            <TextBlock Text="{Binding Detalle}" FontSize="11" Margin="0,1,0,0"
                                       Foreground="{StaticResource Neutral500}" TextTrimming="CharacterEllipsis"/>
                          </StackPanel>
                        </Button>
                        <Button Grid.Column="1" Style="{StaticResource BtnGhostMuted}" Padding="8,6"
                                Content="✕" FontSize="11" Click="OnQuitarDeLaCola"
                                Tag="{Binding Ruta}" ToolTip="Sacar de la cola"/>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>

              <Border Grid.Row="2" BorderBrush="{StaticResource Divider}" BorderThickness="0,1,0,0"
                      Padding="10,7">
                <Button x:Name="btnVaciarCola" Style="{StaticResource BtnGhostMuted}" Padding="8,4"
                        FontSize="11.5" HorizontalAlignment="Right" Content="Vaciar la cola"/>
              </Border>
            </Grid>
          </Border>
        </Popup>

        <Button x:Name="btnMemoria" Style="{StaticResource BtnGhostMuted}" Content="Memoria de decisiones…"
                ToolTip="Ver y olvidar las decisiones que has ido tomando"/>
      </StackPanel>
    </Grid>

    <!-- ══════════════ Confirmación (superpuesta, no MessageBox) ══════════════ -->
    <!-- Va dentro de la ventana a propósito: un MessageBox del sistema rompería el tema
         y sacaría al usuario del contexto justo en la decisión más delicada. -->
    <Grid x:Name="overlayConfirmar" Grid.RowSpan="4" Background="#B0000000" Visibility="Collapsed"
          Panel.ZIndex="10">
      <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Divider}" BorderThickness="1"
              CornerRadius="12" MaxWidth="560" VerticalAlignment="Center" HorizontalAlignment="Center"
              Padding="24,20">
        <StackPanel>
          <TextBlock Text="Aplicar el renombrado" FontSize="16" FontWeight="Medium"
                     Foreground="{StaticResource Text}" Margin="0,0,0,14"/>

          <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="✓" Foreground="{StaticResource OrgOk}" Margin="0,0,9,0" VerticalAlignment="Top"/>
            <TextBlock x:Name="lblConfSeRenombra" Foreground="{StaticResource Text}" FontSize="13"
                       TextWrapping="Wrap"/>
          </StackPanel>

          <StackPanel x:Name="filaNoSeToca" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="—" Foreground="{StaticResource Neutral500}" Margin="0,0,9,0" VerticalAlignment="Top"/>
            <TextBlock x:Name="lblConfNoSeToca" Foreground="{StaticResource Neutral400}" FontSize="13"
                       TextWrapping="Wrap"/>
          </StackPanel>

          <Border Background="{StaticResource Accent900}" BorderBrush="{StaticResource Accent800}" BorderThickness="1"
                  CornerRadius="8" Padding="12,9" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="↺" Foreground="{StaticResource Accent300}" Margin="0,0,9,0" VerticalAlignment="Top"/>
              <TextBlock Foreground="{StaticResource Accent200}" FontSize="12.5" TextWrapping="Wrap"
                         Text="Se guarda un registro del lote antes de tocar nada: podrás deshacerlo entero cuando quieras."/>
            </StackPanel>
          </Border>

          <CheckBox x:Name="chkRecordarDecisiones" Margin="0,14,0,0" Foreground="{StaticResource Neutral400}"
                    FontSize="12.5" Visibility="Collapsed"/>

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnConfCancelar" Style="{StaticResource BtnSecondary}" Content="Cancelar"/>
            <Button x:Name="btnConfAceptar" Style="{StaticResource BtnPrimary}" Content="Aplicar" Margin="8,0,0,0"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</UserControl>
