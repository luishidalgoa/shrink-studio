<UserControl x:Class="ShrinkVideo.RecortesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource FontUI}" Foreground="{StaticResource Text}">
  <Grid Margin="0,8,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>   <!-- origen -->
      <RowDefinition Height="*"/>      <!-- vídeo + tramos -->
      <RowDefinition Height="Auto"/>   <!-- salida -->
    </Grid.RowDefinitions>

    <!-- ══ De dónde sale el vídeo ══ -->
    <Border Grid.Row="0" Background="{StaticResource Surface}" CornerRadius="8" Padding="12,10"
            BorderBrush="{StaticResource Divider}" BorderThickness="1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Button x:Name="btnElegir" Grid.Column="0" Style="{StaticResource BtnPrimary}"
                Content="Elegir vídeo…" Padding="14,6"/>
        <StackPanel Grid.Column="1" Margin="14,0,10,0" VerticalAlignment="Center">
          <TextBlock x:Name="lblVideo" Text="Ningún vídeo cargado" FontSize="12.5" FontWeight="Medium"
                     TextTrimming="CharacterEllipsis"/>
          <TextBlock x:Name="lblVideoDet" FontSize="11" Foreground="{StaticResource Neutral500}"
                     Text="Arrastra un vídeo aquí, o ábrelo desde Organizar con el botón derecho."/>
        </StackPanel>
        <TextBlock x:Name="lblDuracionTotal" Grid.Column="2" VerticalAlignment="Center"
                   FontFamily="{StaticResource FontMono}" FontSize="12"
                   Foreground="{StaticResource Neutral400}" Text=""/>
      </Grid>
    </Border>

    <!-- ══ Vídeo y tramos ══ -->
    <Grid Grid.Row="1" Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/><ColumnDefinition Width="300"/>
      </Grid.ColumnDefinitions>

      <!-- reproductor con la barra de posición y las marcas de corte -->
      <Border Grid.Column="0" Background="#08090F" CornerRadius="8" ClipToBounds="True"
              BorderBrush="{StaticResource Divider}" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/><RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <Grid Grid.Row="0" Background="Black">
            <MediaElement x:Name="video" LoadedBehavior="Manual" UnloadedBehavior="Stop" Stretch="Uniform"/>
            <TextBlock x:Name="lblSinVideo" Text="Elige un vídeo para empezar a cortarlo"
                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12.5"
                       Foreground="{StaticResource Neutral600}"/>
          </Grid>

          <StackPanel Grid.Row="1" Margin="14,8,14,12">
            <!-- La regla de tramos va PEGADA encima de la barra: es la misma línea de
                 tiempo, y separarlas obligaría a traducir mentalmente de una a otra. -->
            <Canvas x:Name="regla" Height="10" Margin="0,0,0,1" ClipToBounds="True"
                    ToolTip="Los tramos que se exportarán, cada uno un fichero. Se dibujan sobre la misma línea de tiempo que la barra de abajo."/>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="lblPos" VerticalAlignment="Center" Margin="0,0,11,0" MinWidth="46"
                         TextAlignment="Right" FontFamily="{StaticResource FontMono}" FontSize="11"
                         Foreground="#D6D9E8" Text="0:00"/>
              <Slider x:Name="barra" Grid.Column="1" Style="{StaticResource BarraVideo}" VerticalAlignment="Center"/>
              <TextBlock x:Name="lblDur" Grid.Column="2" VerticalAlignment="Center" Margin="11,0,0,0" MinWidth="46"
                         FontFamily="{StaticResource FontMono}" FontSize="11"
                         Foreground="#B9BECF" Text="0:00"/>
            </Grid>

            <Grid Margin="0,8,0,0">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button x:Name="btnAtras" Style="{StaticResource BtnIcono}" Margin="0,0,10,0"
                        ToolTip="Atrás 10 s  (flecha izquierda)">
                  <Path Data="M10,5 L4.5,10 L10,15 M16,5 L10.5,10 L16,15" Stretch="None" Width="20" Height="20"
                        Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                </Button>
                <Button x:Name="btnPlay" Style="{StaticResource BtnPlay}" ToolTip="Reproducir / pausar  (espacio)">
                  <Path x:Name="glifoPlay" Stretch="None" Data="M6.5,3.5 L17,10 L6.5,16.5 Z" Fill="White"
                        Stroke="White" StrokeThickness="2.2" StrokeLineJoin="Round" Width="19" Height="20"/>
                </Button>
                <Button x:Name="btnAdelante" Style="{StaticResource BtnIcono}" Margin="10,0,0,0"
                        ToolTip="Adelante 10 s  (flecha derecha)">
                  <Path Data="M10,5 L15.5,10 L10,15 M4,5 L9.5,10 L4,15" Stretch="None" Width="20" Height="20"
                        Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                </Button>
              </StackPanel>
              <Button x:Name="btnCortar" HorizontalAlignment="Right" VerticalAlignment="Center"
                      Style="{StaticResource BtnPrimary}" Padding="14,6" IsEnabled="False"
                      Content="✂  Cortar aquí" ToolTip="Parte en dos el tramo por donde va la reproducción  (C)"/>
            </Grid>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ══ Lista de tramos ══ -->
      <Border Grid.Column="1" Margin="10,0,0,0" Background="{StaticResource Surface}" CornerRadius="8"
              BorderBrush="{StaticResource Divider}" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <StackPanel Grid.Row="0" Margin="12,10,12,6">
            <TextBlock Text="TRAMOS" FontSize="10.5" FontWeight="SemiBold" Opacity="0.65"/>
            <TextBlock x:Name="lblAyudaTramos" FontSize="11" Foreground="{StaticResource Neutral500}"
                       TextWrapping="Wrap" Margin="0,3,0,0"
                       Text="Cada tramo será un fichero. Corta por donde quieras y ponles nombre."/>
          </StackPanel>
          <ItemsControl x:Name="listaTramos" Grid.Row="1" Margin="8,0,8,8">
            <ItemsControl.Template>
              <ControlTemplate TargetType="ItemsControl">
                <ScrollViewer VerticalScrollBarVisibility="Auto"><ItemsPresenter/></ScrollViewer>
              </ControlTemplate>
            </ItemsControl.Template>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="{StaticResource Field}" CornerRadius="6" Padding="9,7" Margin="0,0,0,6"
                        BorderBrush="{StaticResource Divider}" BorderThickness="1">
                  <StackPanel>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>
                      <Border Background="{StaticResource Accent800}" CornerRadius="4" Padding="5,1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Numero}" FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource Accent200}"/>
                      </Border>
                      <TextBlock Grid.Column="1" Margin="7,0,0,0" VerticalAlignment="Center"
                                 FontFamily="{StaticResource FontMono}" FontSize="10.5"
                                 Foreground="{StaticResource Neutral400}" Text="{Binding Rango}"/>
                      <Button Grid.Column="2" Tag="{Binding}" Click="OnQuitarTramo"
                              Style="{StaticResource BtnIcono}" Width="24" Height="24"
                              ToolTip="Quitar este tramo (no se exportará)">
                        <Path Data="M3,3 L11,11 M11,3 L3,11" Stretch="None" Width="14" Height="14"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.3" StrokeStartLineCap="Round"/>
                      </Button>
                    </Grid>
                    <TextBox Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0"
                             FontSize="11.5" ToolTip="Nombre del fichero que se creará (sin extensión)"/>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Grid>
      </Border>
    </Grid>

    <!-- ══ Salida: los MISMOS ajustes y la MISMA estimación que Comprimir ══ -->
    <Border Grid.Row="2" Margin="0,10,0,0" Background="{StaticResource Surface}" CornerRadius="8"
            Padding="12,10" BorderBrush="{StaticResource Divider}" BorderThickness="1">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock Text="Formato" FontSize="11" Foreground="{StaticResource Neutral500}" Margin="0,0,0,4"/>
            <ComboBox x:Name="cboFmt" SelectedIndex="0"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Margin="0,0,10,0">
            <TextBlock Text="Códec" FontSize="11" Foreground="{StaticResource Neutral500}" Margin="0,0,0,4"/>
            <ComboBox x:Name="cboCodec" SelectedIndex="0"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Margin="0,0,10,0">
            <TextBlock Text="Calidad" FontSize="11" Foreground="{StaticResource Neutral500}" Margin="0,0,0,4"/>
            <ComboBox x:Name="cboQ" SelectedIndex="0"/>
          </StackPanel>
          <StackPanel Grid.Column="3" Margin="0,0,10,0">
            <TextBlock Text="Resolución máx." FontSize="11" Foreground="{StaticResource Neutral500}" Margin="0,0,0,4"/>
            <ComboBox x:Name="cboRes" SelectedIndex="0"/>
          </StackPanel>
          <StackPanel Grid.Column="4">
            <TextBlock Text="Audio" FontSize="11" Foreground="{StaticResource Neutral500}" Margin="0,0,0,4"/>
            <ComboBox x:Name="cboAud" SelectedIndex="0"/>
          </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,10,0,0">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="lblEst" FontSize="15" FontWeight="Medium"
                       Foreground="{StaticResource Accent200}" Text="—" VerticalAlignment="Center"/>
            <TextBlock x:Name="lblEstDet" FontSize="11" Foreground="{StaticResource Neutral500}"
                       Margin="10,0,0,0" VerticalAlignment="Center" Text="Elige un vídeo para estimar el tamaño"/>
          </StackPanel>
          <TextBlock x:Name="lblDestino" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="0,26,0,0" FontSize="10.5" Foreground="{StaticResource Neutral600}"
                     TextTrimming="CharacterEllipsis" MaxWidth="620" Text=""/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock x:Name="lblProgreso" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="11.5"
                       Foreground="{StaticResource Neutral400}" Text=""/>
            <Button x:Name="btnDestino" Style="{StaticResource BtnSecondary}" Padding="10,6" Margin="0,0,8,0"
                    Content="Guardar en…" ToolTip="Por defecto, junto al vídeo original"/>
            <Button x:Name="btnExportar" Style="{StaticResource BtnPrimary}" Padding="16,7"
                    Content="Exportar" IsEnabled="False"/>
          </StackPanel>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</UserControl>
